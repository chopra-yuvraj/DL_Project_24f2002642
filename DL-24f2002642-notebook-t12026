    "X_images = []\n",
    "y_labels = []\n",
    "\n",
    "STEMS_PATH = None\n",
    "for root, dirs, files in os.walk('/kaggle/input'):\n",
    "    if 'genres_stems' in dirs:\n",
    "        STEMS_PATH = os.path.join(root, 'genres_stems')\n",
    "        break\n",
    "\n",
    "if not STEMS_PATH:\n",
    "    raise FileNotFoundError(\"Dataset not found.\")\n",
    "\n",
    "noise_dir = '/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup/ESC-50-master/audio'\n",
    "genres = os.listdir(STEMS_PATH)\n",
    "noise_files = []\n",
    "\n",
    "if os.path.exists(noise_dir):\n",
    "    noise_files = [os.path.join(noise_dir, f) for f in os.listdir(noise_dir) if f.endswith('.wav')]\n",
    "\n",
    "for genre in genres:\n",
    "    genre_path = os.path.join(STEMS_PATH, genre)\n",
    "    if os.path.isdir(genre_path):\n",
    "        song_folders = os.listdir(genre_path)\n",
    "        for song in tqdm(song_folders):\n",
    "            song_path = os.path.join(genre_path, song)\n",
    "            stems = os.listdir(song_path)\n",
    "            \n",
    "            mixed_y = None\n",
    "            sr_val = 22050\n",
    "            \n",
    "            for stem in stems:\n",
    "                if stem.endswith('.wav'):\n",
    "                    stem_path = os.path.join(song_path, stem)\n",
    "                    try:\n",
    "                        audio_y, sr = librosa.load(stem_path, duration=30)\n",
    "                        if mixed_y is None:\n",
    "                            mixed_y = audio_y\n",
    "                        else:\n",
    "                            min_len = min(len(mixed_y), len(audio_y))\n",
    "                            mixed_y = mixed_y[:min_len] + audio_y[:min_len]\n",
    "                    except Exception:\n",
    "                        continue\n",
    "            \n",
    "            if mixed_y is not None and len(noise_files) > 0:\n",
    "                try:\n",
    "                    random_noise_path = np.random.choice(noise_files)\n",
    "                    noise_y, _ = librosa.load(random_noise_path, duration=30)\n",
    "                    min_len = min(len(mixed_y), len(noise_y))\n",
    "                    mixed_y[:min_len] = mixed_y[:min_len] + (noise_y[:min_len] * 0.25) \n",
    "                except Exception:\n",
    "                    pass\n",
    "            \n",
    "            if mixed_y is not None:\n",
    "                img = get_spectrogram(mixed_y, sr_val)\n",
    "                if img is not None:\n",
    "                    img_3c = np.stack((img,)*3, axis=-1)\n",
    "                    X_images.append(img_3c)\n",
    "                    y_labels.append(genre)\n",
    "\n",
    "X = np.array(X_images, dtype=np.float32)\n",
    "y_target = np.array(y_labels)"
