    "test_df = pd.read_csv(TEST_CSV)\n",
    "\n",
    "id_to_filename = {}\n",
    "for fname in os.listdir(TEST_DIR):\n",
    "    if not fname.endswith('.wav'):\n",
    "        continue\n",
    "    digits = ''.join(filter(str.isdigit, fname))\n",
    "    if digits:\n",
    "        id_to_filename[int(digits)] = fname\n",
    "\n",
    "print(f'Test tracks in CSV  : {len(test_df)}')\n",
    "print(f'Test WAV files found: {len(id_to_filename)}')\n",
    "\n",
    "model.load_state_dict(torch.load(os.path.join(OUTPUT_DIR, 'best_model.pth'), map_location=device))\n",
    "model.eval()\n",
    "print('Best model loaded for inference.')\n",
    "\n",
    "\n",
    "\n",
    "NOISE_LEVELS = [0.0, 0.005, 0.01, 0.015, 0.02] \n",
    "\n",
    "@torch.no_grad()\n",
    "def tta_predict(wf_tensor):\n",
    "    prob_acc = None\n",
    "    for nl in NOISE_LEVELS:\n",
    "        noisy = wf_tensor.clone()\n",
    "        if nl > 0:\n",
    "            noisy = noisy + torch.randn_like(noisy) * nl\n",
    "        with autocast():\n",
    "            logits = model(noisy, augment=False)\n",
    "        probs = torch.softmax(logits, dim=1)\n",
    "        prob_acc = probs if prob_acc is None else prob_acc + probs\n",
    "    avg_probs = prob_acc / len(NOISE_LEVELS)\n",
    "    return avg_probs.argmax(1).cpu().item()\n",
    "\n",
    "\n",
    "\n",
    "submission_rows = []\n",
    "\n",
    "for _, row in tqdm(test_df.iterrows(), total=len(test_df), desc='TTA Inference'):\n",
    "    song_id  = row['id']\n",
    "    filename = id_to_filename.get(song_id)\n",
    "    fallback = 'pop'\n",
    "\n",
    "    if filename is None:\n",
    "        submission_rows.append([song_id, fallback])\n",
    "        continue\n",
    "\n",
    "    try:\n",
    "        file_path  = os.path.join(TEST_DIR, filename)\n",
    "        waveform, sr = torchaudio.load(file_path)\n",
    "\n",
    "        if sr != TARGET_SR:\n",
    "            waveform = T.Resample(sr, TARGET_SR)(waveform)\n",
    "        if waveform.shape[0] > 1:\n",
    "            waveform = waveform.mean(dim=0, keepdim=True)\n",
    "\n",
    "        # Strict pad / trim to exactly 30 s\n",
    "        if waveform.shape[1] < TARGET_LENGTH:\n",
    "            waveform = F.pad(waveform, (0, TARGET_LENGTH - waveform.shape[1]))\n",
    "        else:\n",
    "            waveform = waveform[:, :TARGET_LENGTH]\n",
    "\n",
    "        # Peak normalise\n",
    "        peak = torch.max(torch.abs(waveform))\n",
    "        if peak > 1e-6:\n",
    "            waveform = waveform / peak\n",
    "\n",
    "        waveform = waveform.unsqueeze(0).to(device)  \n",
    "\n",
    "        pred_idx   = tta_predict(waveform)\n",
    "        pred_label = label_encoder.inverse_transform([pred_idx])[0]\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f'  Error on id={song_id}: {e}')\n",
    "        pred_label = fallback\n",
    "\n",
    "    submission_rows.append([song_id, pred_label])\n",
    "\n",
    "submission_df = pd.DataFrame(submission_rows, columns=['id', 'genre'])\n",
    "submission_path = os.path.join(OUTPUT_DIR, 'submission.csv')\n",
    "submission_df.to_csv(submission_path, index=False)\n",
    "\n",
    "print(f'\\nsubmission.csv saved to {submission_path}')\n",
    "print(f'Rows: {len(submission_df)}')\n",
    "print('\\nPredicted class distribution:')\n",
    "print(submission_df['genre'].value_counts())\n"
