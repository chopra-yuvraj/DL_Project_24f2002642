    "mel_transform = AT.MelSpectrogram(\n",
    "    sample_rate=SR, n_fft=N_FFT, hop_length=HOP_LENGTH,\n",
    "    n_mels=N_MELS, f_min=20, f_max=8000\n",
    ").to(DEVICE)\n",
    "\n",
    "amp_to_db  = AT.AmplitudeToDB(top_db=80).to(DEVICE)\n",
    "time_mask  = AT.TimeMasking(time_mask_param=80).to(DEVICE)\n",
    "freq_mask  = AT.FrequencyMasking(freq_mask_param=30).to(DEVICE)\n",
    "\n",
    "\n",
    "def to_mel(wav, augment=False):\n",
    "    spec = mel_transform(wav)\n",
    "    spec = amp_to_db(spec)\n",
    "    if augment:\n",
    "        spec = freq_mask(time_mask(spec))\n",
    "    mu  = spec.mean(dim=(-2, -1), keepdim=True)\n",
    "    std = spec.std(dim=(-2, -1), keepdim=True) + 1e-6\n",
    "    return (spec - mu) / std\n",
    "\n",
    "\n",
    "class ResBlock(nn.Module):\n",
    "    def __init__(self, in_ch, out_ch, stride=1):\n",
    "        super().__init__()\n",
    "        self.conv = nn.Sequential(\n",
    "            nn.Conv2d(in_ch, out_ch, 3, padding=1, stride=stride, bias=False),\n",
    "            nn.BatchNorm2d(out_ch),\n",
    "            nn.ReLU(inplace=True),\n",
    "            nn.Conv2d(out_ch, out_ch, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(out_ch),\n",
    "        )\n",
    "        self.skip = (\n",
    "            nn.Sequential(\n",
    "                nn.Conv2d(in_ch, out_ch, 1, stride=stride, bias=False),\n",
    "                nn.BatchNorm2d(out_ch)\n",
    "            ) if (in_ch != out_ch or stride != 1) else nn.Identity()\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        return F.relu(self.conv(x) + self.skip(x))\n",
    "\n",
    "\n",
    "class MelCNN(nn.Module):\n",
    "    def __init__(self, num_classes=10):\n",
    "        super().__init__()\n",
    "        self.stem   = nn.Sequential(\n",
    "            nn.Conv2d(1, 32, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(32),\n",
    "            nn.ReLU(inplace=True),\n",
    "        )\n",
    "        self.stage1 = nn.Sequential(ResBlock(32,  64),  nn.MaxPool2d(2))\n",
    "        self.stage2 = nn.Sequential(ResBlock(64,  128), nn.MaxPool2d(2))\n",
    "        self.stage3 = nn.Sequential(ResBlock(128, 256), nn.MaxPool2d(2))\n",
    "        self.stage4 = nn.Sequential(ResBlock(256, 512), nn.MaxPool2d(2))\n",
    "        self.gap    = nn.AdaptiveAvgPool2d(1)\n",
    "        self.head   = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(512, 256),\n",
    "            nn.ReLU(inplace=True),\n",
    "            nn.Dropout(0.4),\n",
    "            nn.Linear(256, num_classes)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.stem(x)\n",
    "        x = self.stage1(x)\n",
    "        x = self.stage2(x)\n",
    "        x = self.stage3(x)\n",
    "        x = self.stage4(x)\n",
    "        x = self.gap(x)\n",
    "        return self.head(x)\n",
    "\n",
    "\n",
    "model = MelCNN(num_classes=len(GENRES)).to(DEVICE)\n",
    "print(f'MelCNN on {DEVICE} | Params: {sum(p.numel() for p in model.parameters()):,}')"
   ]
