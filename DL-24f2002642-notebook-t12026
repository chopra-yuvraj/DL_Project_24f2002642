    "class TransferAudioCNN(nn.Module):\n",
    "    def __init__(self, num_classes=10):\n",
    "        super(TransferAudioCNN, self).__init__()\n",
    "        \n",
    "        self.mel = T.MelSpectrogram(sample_rate=22050, n_mels=128, n_fft=2048, hop_length=512)\n",
    "        self.amp_to_db = T.AmplitudeToDB()\n",
    "        \n",
    "        self.freq_mask = T.FrequencyMasking(freq_mask_param=15)\n",
    "        self.time_mask = T.TimeMasking(time_mask_param=35)\n",
    "        \n",
    "        self.backbone = models.efficientnet_b1(weights=models.EfficientNet_B1_Weights.DEFAULT)\n",
    "        \n",
    "        num_ftrs = self.backbone.classifier[1].in_features\n",
    "        self.backbone.classifier = nn.Sequential(\n",
    "            nn.Dropout(p=0.5),\n",
    "            nn.Linear(num_ftrs, 256),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(p=0.3),\n",
    "            nn.Linear(256, num_classes)\n",
    "        )\n",
    "\n",
    "    def forward(self, x, augment=False):\n",
    "        with torch.no_grad():\n",
    "            x = self.mel(x)\n",
    "            x = self.amp_to_db(x)\n",
    "            if augment:\n",
    "                x = self.freq_mask(x)\n",
    "                x = self.time_mask(x)\n",
    "            \n",
    "            x = x.repeat(1, 3, 1, 1) \n",
    "            \n",
    "        return self.backbone(x)\n",
    "\n",
    "model = TransferAudioCNN(num_classes=10).to(device)\n",
    "criterion = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
    "\n",
    "optimizer = optim.AdamW(model.parameters(), lr=0.0003, weight_decay=1e-2)\n",
    "scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=25, eta_min=1e-6)"
   ]
