    "test_csv_path = '/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup/test.csv'\n",
    "test_dir = '/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup/mashups'\n",
    "test_df = pd.read_csv(test_csv_path)\n",
    "\n",
    "actual_files = os.listdir(test_dir)\n",
    "id_to_filename = {}\n",
    "for filename in actual_files:\n",
    "    if not filename.endswith('.wav'): continue\n",
    "    digits = ''.join(filter(str.isdigit, filename))\n",
    "    if digits:\n",
    "        id_to_filename[int(digits)] = filename\n",
    "\n",
    "model.load_state_dict(torch.load('best_model.pth'))\n",
    "model.eval()\n",
    "\n",
    "submission_data = []\n",
    "target_sr = 22050\n",
    "max_length = target_sr * 30  \n",
    "\n",
    "with torch.no_grad():\n",
    "    for index, row in tqdm(test_df.iterrows(), total=len(test_df), desc=\"Inference\"):\n",
    "        song_id = row['id']\n",
    "        filename = id_to_filename.get(song_id)\n",
    "        \n",
    "        if filename:\n",
    "            file_path = os.path.join(test_dir, filename)\n",
    "            try:\n",
    "                waveform, sr = torchaudio.load(file_path)\n",
    "                if sr != target_sr:\n",
    "                    resampler = T.Resample(sr, target_sr)\n",
    "                    waveform = resampler(waveform)\n",
    "                \n",
    "                if waveform.shape[0] > 1:\n",
    "                    waveform = torch.mean(waveform, dim=0, keepdim=True)\n",
    "                \n",
    "                if waveform.shape[1] < max_length:\n",
    "                    pad_amount = max_length - waveform.shape[1]\n",
    "                    waveform = torch.nn.functional.pad(waveform, (0, pad_amount))\n",
    "                else:\n",
    "                    waveform = waveform[:, :max_length]\n",
    "                    \n",
    "                waveform = waveform / (torch.max(torch.abs(waveform)) + 1e-6)\n",
    "                waveform = waveform.unsqueeze(0).to(device)\n",
    "                \n",
    "                outputs = model(waveform)\n",
    "                _, predicted = outputs.max(1)\n",
    "                pred_label = label_encoder.inverse_transform([predicted.cpu().item()])[0]\n",
    "                submission_data.append([song_id, pred_label])\n",
    "            except Exception:\n",
    "                submission_data.append([song_id, \"pop\"])\n",
    "        else:\n",
    "            submission_data.append([song_id, \"pop\"])\n",
    "\n",
    "submission_df = pd.DataFrame(submission_data, columns=['id', 'genre'])\n",
    "submission_df.to_csv('submission.csv', index=False)"
