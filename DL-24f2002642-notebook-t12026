    "test_df = pd.read_csv(TEST_CSV)\n",
    "\n",
    "id_to_file = {}\n",
    "for f in os.listdir(TEST_DIR):\n",
    "    if f.endswith('.wav'):\n",
    "        digits = ''.join(filter(str.isdigit, f))\n",
    "        if digits:\n",
    "            id_to_file[int(digits)] = f\n",
    "\n",
    "model1 = build_model('efficientnet_b1')\n",
    "model1.load_state_dict(torch.load('/kaggle/working/model1_b1.pth', map_location=device))\n",
    "model1.eval()\n",
    "\n",
    "model2 = build_model('efficientnet_b0')\n",
    "model2.load_state_dict(torch.load('/kaggle/working/model2_b0.pth', map_location=device))\n",
    "model2.eval()\n",
    "\n",
    "model3 = build_model('resnet50')\n",
    "model3.load_state_dict(torch.load('/kaggle/working/model3_resnet50.pth', map_location=device))\n",
    "model3.eval()\n",
    "\n",
    "ensemble_models = [model1, model2, model3]\n",
    "\n",
    "freq_mask = T.FrequencyMasking(freq_mask_param=15)\n",
    "time_mask = T.TimeMasking(time_mask_param=60)\n",
    "\n",
    "\n",
    "def make_tta_versions(spec_np):\n",
    "    base = torch.tensor(spec_np).unsqueeze(0)\n",
    "    versions = [base.clone()]\n",
    "    for _ in range(3):\n",
    "        aug = time_mask(freq_mask(base.clone()))\n",
    "        versions.append(aug)\n",
    "    return [v.repeat(3, 1, 1).unsqueeze(0).to(device) for v in versions]\n",
    "\n",
    "\n",
    "rows = []\n",
    "for _, row in tqdm(test_df.iterrows(), total=len(test_df)):\n",
    "    sid   = row['id']\n",
    "    fname = id_to_file.get(sid)\n",
    "    label = 'pop'\n",
    "\n",
    "    if fname:\n",
    "        try:\n",
    "            y, _ = librosa.load(os.path.join(TEST_DIR, fname), sr=SR, duration=30)\n",
    "            spec  = get_mel_spec(y)\n",
    "            spec  = (spec - X_mean) / X_std\n",
    "            tta_inputs = make_tta_versions(spec)\n",
    "\n",
    "            prob_sum = None\n",
    "            with torch.no_grad():\n",
    "                for m in ensemble_models:\n",
    "                    for inp in tta_inputs:\n",
    "                        p = torch.softmax(m(inp), dim=1)\n",
    "                        prob_sum = p if prob_sum is None else prob_sum + p\n",
    "\n",
    "            pred_idx = (prob_sum / (len(ensemble_models) * len(tta_inputs))).argmax(1).item()\n",
    "            label    = label_encoder.inverse_transform([pred_idx])[0]\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "    rows.append([sid, label])\n",
    "\n",
    "submission = pd.DataFrame(rows, columns=['id', 'genre'])\n",
    "submission.to_csv('/kaggle/working/submission.csv', index=False)\n",
    "print(submission['genre'].value_counts())"
   ]
