=0)\n        chroma_var = np.var(chroma.T, axis=0)\n        \n        zcr = librosa.feature.zero_crossing_rate(y)\n        zcr_mean = np.mean(zcr)\n        zcr_var = np.var(zcr)\n        \n        rolloff = librosa.feature.spectral_rolloff(y=y, sr=sr)\n        rolloff_mean = np.mean(rolloff)\n        \n        features = np.concatenate([\n            mfcc_mean, mfcc_var, \n            [cent_mean, cent_var], \n            chroma_mean, chroma_var,\n            [zcr_mean, zcr_var, rolloff_mean]\n        ])\n        \n        return features\n    except Exception:\n        return None","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-19T09:03:36.609665Z","iopub.execute_input":"2026-02-19T09:03:36.610167Z","iopub.status.idle":"2026-02-19T09:03:36.620702Z","shell.execute_reply.started":"2026-02-19T09:03:36.610135Z","shell.execute_reply":"2026-02-19T09:03:36.619649Z"}},"outputs":[],"execution_count":2},{"cell_type":"markdown","source":"# Preparing Training Data","metadata":{}},{"cell_type":"code","source":"X_features = []\ny_labels = []\n\ntrain_dir = '/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup/genres_stems'\ngenres = os.listdir(train_dir)\n\nfor genre in genres:\n    genre_path = os.path.join(train_dir, genre)\n    if os.path.isdir(genre_path):\n        song_folders = os.listdir(genre_path)\n        for song in tqdm(song_folders):\n            song_path = os.path.join(genre_path, song)\n            stems = os.listdir(song_path)\n            \n            mixed_y = None\n            sr_val = 22050\n            \n            for stem in stems:\n                if stem.endswith('.wav'):\n                    stem_path = os.path.join(song_path, stem)\n                    try:\n                        y, sr = librosa.load(stem_path, duration=30)\n                        if mixed_y is None:\n                            mixed_y = y\n                        else:\n                            min_len = min(len(mixed_y), len(y))\n                      