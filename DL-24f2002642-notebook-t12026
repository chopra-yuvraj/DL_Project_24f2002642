    "\n",
    "    def __len__(self):\n",
    "        return len(self.samples)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        genre, song_path = self.samples[idx]\n",
    "        mixed = None\n",
    "        for stem in REQUIRED_STEMS:\n",
