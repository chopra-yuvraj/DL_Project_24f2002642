    "X_train = []\n",
    "y_train = []\n",
    "\n",
    "for genre in GENRES:\n",
    "    genre_path = os.path.join(GENRES_PATH, genre)\n",
    "    song_dirs  = sorted([\n",
    "        os.path.join(genre_path, d)\n",
    "        for d in os.listdir(genre_path)\n",
    "        if os.path.isdir(os.path.join(genre_path, d))\n",
    "        and all(os.path.exists(os.path.join(genre_path, d, s)) for s in STEMS)\n",
    "    ])\n",
    "\n",
    "    song_dirs = song_dirs[:SONGS_PER_GENRE]\n",
    "\n",
    "    for song_path in tqdm(song_dirs, desc=genre):\n",
    "        try:\n",
    "            audio = load_and_mix(song_path)\n",
    "            for _ in range(CLIPS_PER_SONG):\n",
    "                clip  = random_crop(audio)\n",
    "                feats = extract_features(clip)\n",
    "                X_train.append(feats)\n",
    "                y_train.append(label2id[genre])\n",
    "        except Exception as e:\n",
    "            print(f'  skip {song_path}: {e}')\n",
    "\n",
    "X_train = np.array(X_train)\n",
    "y_train = np.array(y_train)\n",
    "print(f'\\nTrain set: {X_train.shape}, labels: {y_train.shape}')"
