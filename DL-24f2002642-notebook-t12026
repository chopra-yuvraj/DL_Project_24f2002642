    "def get_mel_spec(y):\n",
    "    mel  = librosa.feature.melspectrogram(y=y, sr=SR, n_mels=N_MELS, fmax=8000)\n",
    "    spec = librosa.power_to_db(mel, ref=np.max)\n",
    "    if spec.shape[1] < MAX_LEN:\n",
    "        spec = np.pad(spec, ((0, 0), (0, MAX_LEN - spec.shape[1])))\n",
    "    else:\n",
    "        spec = spec[:, :MAX_LEN]\n",
    "    return spec.astype(np.float32)\n",
    "\n",
    "\n",
    "noise_files = [os.path.join(NOISE_PATH, f) for f in os.listdir(NOISE_PATH) if f.endswith('.wav')]\n",
    "genres      = sorted([g for g in os.listdir(STEMS_PATH) if os.path.isdir(os.path.join(STEMS_PATH, g))])\n",
    "\n",
    "X_all          = []\n",
    "y_all          = []\n",
    "genre_spec_dict = {g: [] for g in genres}\n",
    "\n",
    "for genre in genres:\n",
    "    gpath = os.path.join(STEMS_PATH, genre)\n",
    "    for song in tqdm(sorted(os.listdir(gpath)), desc=genre):\n",
    "        spath = os.path.join(gpath, song)\n",
    "        if not os.path.isdir(spath):\n",
    "            continue\n",
    "\n",
    "        mixed = None\n",
    "        for stem_file in os.listdir(spath):\n",
    "            if not stem_file.endswith('.wav'):\n",
    "                continue\n",
    "            try:\n",
    "                y, _ = librosa.load(os.path.join(spath, stem_file), sr=SR, duration=30)\n",
    "                if mixed is None:\n",
    "                    mixed = y\n",
    "                else:\n",
    "                    ml    = min(len(mixed), len(y))\n",
    "                    mixed = mixed[:ml] + y[:ml]\n",
    "            except Exception:\n",
    "                continue\n",
    "\n",
    "        if mixed is not None and noise_files:\n",
    "            n_noises = random.randint(1, 2)\n",
    "            for _ in range(n_noises):\n",
    "                try:\n",
    "                    ny, _ = librosa.load(random.choice(noise_files), sr=SR, duration=30)\n",
    "                    ml    = min(len(mixed), len(ny))\n",
    "                    start = random.randint(0, max(1, len(mixed) - ml))\n",
    "                    mixed[start:start + ml] += ny[:ml] * random.uniform(0.1, 0.35)\n",
    "                except Exception:\n",
    "                    continue\n",
    "\n",
    "        if mixed is not None:\n",
    "            spec = get_mel_spec(mixed)\n",
    "            X_all.append(spec)\n",
    "            y_all.append(genre)\n",
    "            genre_spec_dict[genre].append(spec)\n",
    "\n",
    "X = np.array(X_all, dtype=np.float32)\n",
    "print(X.shape)"
   ]
