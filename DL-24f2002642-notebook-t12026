    "label_encoder = LabelEncoder()\n",
    "y_encoded     = label_encoder.fit_transform(np.array(y_labels))\n",
    "print('Classes:', list(label_encoder.classes_))\n",
    "\n",
    "X_train, X_val, y_train, y_val = train_test_split(\n",
    "    X, y_encoded, test_size=0.2, stratify=y_encoded, random_state=42\n",
    ")\n",
    "\n",
    "X_mean  = X_train.mean()\n",
    "X_std   = X_train.std() + 1e-6\n",
    "X_train = (X_train - X_mean) / X_std\n",
    "X_val   = (X_val   - X_mean) / X_std\n",
    "\n",
    "\n",
    "class SpectrogramDataset(Dataset):\n",
    "    def __init__(self, specs, labels, is_train=True):\n",
    "        self.specs    = specs\n",
    "        self.labels   = labels\n",
    "        self.is_train = is_train\n",
    "        self.freq_m   = T.FrequencyMasking(freq_mask_param=20)\n",
    "        self.time_m   = T.TimeMasking(time_mask_param=80)\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.specs)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        spec = torch.tensor(self.specs[idx]).unsqueeze(0)\n",
    "        if self.is_train:\n",
    "            spec = self.freq_m(spec)\n",
    "            spec = self.time_m(spec)\n",
    "        spec = spec.repeat(3, 1, 1)\n",
    "        return spec, torch.tensor(self.labels[idx], dtype=torch.long)\n",
    "\n",
    "\n",
    "train_ds = SpectrogramDataset(X_train, y_train, is_train=True)\n",
    "val_ds   = SpectrogramDataset(X_val,   y_val,   is_train=False)\n",
    "\n",
    "train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True,  num_workers=2, pin_memory=True)\n",
    "val_loader   = DataLoader(val_ds,   batch_size=BATCH_SIZE, shuffle=False, num_workers=2, pin_memory=True)"
   ]
