    "total_p = sum(p.numel() for p in model.parameters())\n",
    "print(f'All {total_p:,} params unfrozen')\n",
    "\n",
    "opt_p2 = torch.optim.AdamW([\n",
    "    {'params': model.backbone.parameters(), 'lr': LR_P2},\n",
    "    {'params': model.head.parameters(),     'lr': LR_P2 * LR_HEAD_MULT},\n",
    "], weight_decay=WEIGHT_DECAY)\n",
    "\n",
    "total_steps_p2 = len(train_loader) * EPOCHS_P2\n",
    "sch_p2 = get_cosine_schedule_with_warmup(\n",
    "    opt_p2,\n",
    "    num_warmup_steps   = total_steps_p2 // 10,\n",
    "    num_training_steps = total_steps_p2\n",
    ")\n",
    "\n",
    "best_p2_f1   = 0\n",
    "patience_cnt = 0\n",
    "\n",
    "for epoch in range(EPOCHS_P2):\n",
    "    tr_loss, tr_acc, tr_f1  = run_epoch(model, train_loader, opt_p2, sch_p2, augment=True,  train=True)\n",
    "    va_loss, va_acc, val_f1 = run_epoch(model, val_loader,   opt_p2, sch_p2, augment=False, train=False)\n",
    "\n",
    "    wandb.log({'phase': 2, 'epoch': epoch + 1, 'train_loss': tr_loss,\n",
    "               'train_acc': tr_acc, 'train_f1': tr_f1, 'val_f1': val_f1})\n",
    "    print(f'P2 Ep {epoch+1}/{EPOCHS_P2} | loss={tr_loss:.4f} acc={tr_acc:.4f} train_f1={tr_f1:.4f} val_f1={val_f1:.4f}')\n",
    "\n",
    "    if val_f1 > best_p2_f1:\n",
    "        best_p2_f1   = val_f1\n",
    "        patience_cnt = 0\n",
    "        torch.save(model.state_dict(), '/kaggle/working/best_model_phase2.pth')\n",
    "    else:\n",
    "        patience_cnt += 1\n",
    "        if patience_cnt >= PATIENCE_P2:\n",
    "            print('Early stopping Phase 2.')\n",
    "            break\n",
    "\n",
    "wandb.finish()\n",
    "print(f'Phase 2 done — best val F1: {best_p2_f1:.4f}')"
