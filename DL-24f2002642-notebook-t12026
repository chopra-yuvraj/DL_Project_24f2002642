    "mel_transform = T.MelSpectrogram(\n",
    "    sample_rate = SR,\n",
    "    n_fft       = N_FFT,\n",
    "    hop_length  = HOP,\n",
    "    n_mels      = N_MELS,\n",
    "    power       = 2.0\n",
    ").to(DEVICE)\n",
    "\n",
    "db_transform = T.AmplitudeToDB(top_db=80).to(DEVICE)\n",
    "\n",
    "freq_mask = T.FrequencyMasking(freq_mask_param=20).to(DEVICE)\n",
    "time_mask = T.TimeMasking(time_mask_param=40).to(DEVICE)\n",
    "\n",
    "\n",
    "def load_audio(path):\n",
    "    wav, sr = torchaudio.load(path)\n",
    "    if sr != SR:\n",
    "        wav = torchaudio.functional.resample(wav, sr, SR)\n",
    "    return wav[0].numpy().astype(np.float32)\n",
    "\n",
    "\n",
    "def crop_random(audio):\n",
    "    if len(audio) >= N_FRAMES:\n",
    "        start = random.randint(0, len(audio) - N_FRAMES)\n",
    "        return audio[start: start + N_FRAMES]\n",
    "    return np.pad(audio, (0, N_FRAMES - len(audio)))\n",
    "\n",
    "\n",
    "def crop_center(audio):\n",
    "    if len(audio) >= N_FRAMES:\n",
    "        start = (len(audio) - N_FRAMES) // 2\n",
    "        return audio[start: start + N_FRAMES]\n",
    "    return np.pad(audio, (0, N_FRAMES - len(audio)))\n",
    "\n",
    "\n",
    "def normalize(audio):\n",
    "    return audio / (np.max(np.abs(audio)) + 1e-6)\n",
    "\n",
    "\n",
    "def wav_to_3ch(wav, augment=False):\n",
    "    spec = mel_transform(wav.squeeze(1))\n",
    "    spec = db_transform(spec)\n",
    "    d1   = torchaudio.functional.compute_deltas(spec)\n",
    "    d2   = torchaudio.functional.compute_deltas(d1)\n",
    "    def _norm(t):\n",
    "        mu  = t.mean(dim=(-2, -1), keepdim=True)\n",
    "        std = t.std(dim=(-2, -1), keepdim=True)\n",
    "        return (t - mu) / (std + 1e-6)\n",
    "    img = torch.stack([_norm(spec), _norm(d1), _norm(d2)], dim=1)\n",
    "    if augment:\n",
    "        img = freq_mask(img)\n",
    "        img = time_mask(img)\n",
    "    return F.interpolate(img, size=(224, 224), mode='bicubic', align_corners=False)"
   ]
