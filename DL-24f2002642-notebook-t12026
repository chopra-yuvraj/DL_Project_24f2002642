s_stems'\nnoise_dir = '/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup/ESC-50-master/audio'\n\ngenres = os.listdir(train_dir)\nnoise_files = []\n\nif os.path.exists(noise_dir):\n    noise_files = [os.path.join(noise_dir, f) for f in os.listdir(noise_dir) if f.endswith('.wav')]\n\nfor genre in genres:\n    genre_path = os.path.join(train_dir, genre)\n    if os.path.isdir(genre_path):\n        song_folders = os.listdir(genre_path)\n        \n        for _ in tqdm(range(len(song_folders))):\n            mixed_y = None\n            sr_val = 22050\n\n            instrument_files = ['drums.wav', 'bass.wav', 'vocals.wav', 'others.wav']\n            \n            for instr in instrument_files:\n                random_song = np.random.choice(song_folders)\n                stem_path = os.path.join(genre_path, random_song, instr)\n                \n                if not os.path.exists(stem_path) and instr == 'others.wav':\n                    stem_path = os.path.join(genre_path, random_song, 'other.wav')\n                    \n                if os.path.exists(stem_path):\n                    try:\n                        audio_y, sr = librosa.load(stem_path, duration=30)\n                        if mixed_y is None:\n                            mixed_y = audio_y\n                        else:\n                            min_len = min(len(mixed_y), len(audio_y))\n                            mixed_y = mixed_y[:min_len] + audio_y[:min_len]\n                    except Exception:\n                        continue\n            \n            if mixed_y is not None and len(noise_files) > 0:\n                try:\n                    random_noise_path = np.random.choice(noise_files)\n                    noise_y, _ = librosa.load(random_noise_path, duration=30)\n                    min_len = min(len(mixed_y), len(noise_y))\n                    mixed_y[:min_len] = mixed_y[:min_len] + (noise_y[:min_len] * 0.3)\n                except Exception:\n                    pass\n            \n            if mixed_y is not None:\n                img = get_spectrogram(mixed_y, sr_val)\n                if img is not None:\n                    X_images.append(img)\n                    y_labels.append(genre)\n\nX = np.array(X_images)[..., np.newaxis] \ny_target = np.array(y_labels)\n\nprint(f\"Dataset Shape: {X.shape}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-21T16:11:20.223369Z","iopub.execute_input":"2026-02-21T16:11:20.223617Z","iopub.status.idle":"2026-02-21T16:18:01.641955Z","shell.execute_reply.started":"2026-02-21T16:11:20.223589Z","shell.execute_reply":"2026-02-21T16:18:01.641234Z"}},"outputs":[{"name":"stderr","text":"100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:53<00:00,  1.85it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:40<00:00,  2.48it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:40<00:00,  2.48it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:39<00:00,  2.53it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:38<00:00,  2.57it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:35<00:00,  2.83it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:36<00:00,  2.72it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:37<00:00,  2.66it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:38<00:00,  2.60it/s]\n100%|в–€в–€в–€в–€в–€в–€в–€в–€в–€в–€| 100/100 [00:39<00:00,  2.50it/s]","output_type":"stream"},{"name":"stdout","text":"Dataset Shape: (1000, 128, 1292, 1)\n","output_type":"stream"},{"name":"stderr","text":"\n","output_type":"stream"}],"execution_count":3},{"cell_type":"raw","source":"","metadata":{"execution":{"iopub.status.busy":"2026-02-19T11:56:22.390498Z","iopub.execute_input":"2026-02-19T11:56:22.390780Z","iopub.status.idle":"2026-02-19T12:06:55.746864Z","shell.execute_reply.started":"2026-02-19T11:56:22.390761Z","shell.execute_reply":"2026-02-19T12:06:55.745937Z"}},"attachments":{}},{"cell_type":"markdown","source":"# Training Model through W&B","metadata":{}},{"cell_type":"code","source":"run = wandb.init(\n    entity=\"choprayuvraj-iit-madras\",\n    project=\"24f2002642-t12026\",\n    name=\"True-Mashups-VGG\",\n    job_type=\"train\"\n)\n\nlabel_encoder = LabelEncoder()\ny_encoded = label_encoder.fit_transform(y_target)\n\nX_train, X_val, y_train, y_val = train_test_split(X, y_encoded, test_size=0.2, random_state=42)\n\nmodel = models.Sequential([\n    layers.Input(shape=(128, 1292, 1)),\n    \n    layers.Conv2D(32, (3, 3), padding='same', activation='relu'),\n    layers.BatchNormalization(),\n    layers.Conv2D(32, (3, 3), padding='same', activation='relu'),\n    layers.BatchNormalization(),\n    layers.MaxPooling2D((2, 4)),\n    layers.Dropout(0.25),\n    \n    layers.Conv2D(64, (3, 3), padding='same', activation='relu'),\n    layers.BatchNormalization(),\n    layers.Conv2D(64, (3, 3), padding='same', activation='relu'),\n    layers.BatchNormalization(),\n    layers.MaxPooling2D((2, 4)),\n    layers.Dropout(0.25),\n    \n    layers.Conv2D(128, (3, 3), padding='same', activation='relu'),\n    layers.BatchNormalization(),\n    layers.Conv2D(128, (3, 3), padding='same', activation='relu'),\n    layers.BatchNormalization(),\n    layers.MaxPooling2D((2, 4)),\n    layers.Dropout(0.25),\n    \n    layers.GlobalAveragePooling2D(),\n    layers.Dense(256, activation='relu'),\n    layers.Dropout(0.5),\n    layers.Dense(10, activation='softmax')\n])\n\noptimizer = tf.keras.optimizers.Adam(learning_rate=0.001)\n\nmodel.compile(optimizer=optimizer,\n              loss='sparse_categorical_crossentropy',\n              metrics=['accuracy'])\n\nclass SimpleWandbCallback(tf.keras.callbacks.Callback):\n    def on_epoch_end(self, epoch, logs=None):\n        wandb.log(logs)\n\nprint(\"Training VGG on True Mashup Data...\")\nhistory = model.fit(\n    X_train, y_train, \n    epochs=25, \n    batch_size=16,\n    validation_data=(X_val, y_val),\n    callbacks=[SimpleWandbCallback()]\n)\n\nrun.finish()","metadata":{"trusted":true,"execution":{"iopu