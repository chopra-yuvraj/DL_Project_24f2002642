    "def get_3channel_spectrogram(y_audio, sr, max_len=1292):\n",
    "    try:\n",
    "        mel_spec = librosa.feature.melspectrogram(y=y_audio, sr=sr, n_mels=128, fmax=8000)\n",
    "        mel_db = librosa.power_to_db(mel_spec, ref=np.max)\n",
    "        \n",
    "        if mel_db.shape[1] < max_len:\n",
    "            pad_width = max_len - mel_db.shape[1]\n",
    "            mel_db = np.pad(mel_db, pad_width=((0, 0), (0, pad_width)), mode='constant')\n",
    "        else:\n",
    "            mel_db = mel_db[:, :max_len]\n",
    "            \n",
    "        delta = librosa.feature.delta(mel_db)\n",
    "        delta2 = librosa.feature.delta(mel_db, order=2)\n",
    "        \n",
    "        img_3c = np.stack([mel_db, delta, delta2], axis=-1)\n",
    "        \n",
    "        img_min = np.min(img_3c, axis=(0, 1), keepdims=True)\n",
    "        img_max = np.max(img_3c, axis=(0, 1), keepdims=True)\n",
    "        img_3c = (img_3c - img_min) / (img_max - img_min + 1e-6)\n",
    "        img_3c = img_3c * 255.0\n",
    "            \n",
    "        return img_3c\n",
    "    except Exception:\n",
    "        return None"
   ]
