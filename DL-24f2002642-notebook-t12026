    "run = wandb.init(\n",
    "    entity=\"choprayuvraj-iit-madras\",\n",
    "    project=\"24f2002642-t12026\",\n",
    "    name=\"The Grand Ensemble\",\n",
    "    job_type=\"train\"\n",
    ")\n",
    "\n",
    "label_encoder = LabelEncoder()\n",
    "y_encoded = label_encoder.fit_transform(y_target)\n",
    "y_encoded_onehot = tf.keras.utils.to_categorical(y_encoded, num_classes=10).astype(np.float32)\n",
    "\n",
    "def create_mask(shape, start, size):\n",
    "    indices = tf.range(shape)\n",
    "    mask = tf.logical_or(indices < start, indices >= start + size)\n",
    "    return tf.cast(mask, tf.float32)\n",
    "\n",
    "def spec_augment(image, label):\n",
    "    image = tf.cast(image, tf.float32)\n",
    "    label = tf.cast(label, tf.float32)\n",
    "    \n",
    "    f_mask = tf.random.uniform([], 0, 20, dtype=tf.int32)\n",
    "    f0 = tf.random.uniform([], 0, 128 - f_mask, dtype=tf.int32)\n",
    "    mask_f = create_mask(128, f0, f_mask)\n",
    "    mask_f = tf.reshape(mask_f, [128, 1, 1])\n",
    "    \n",
    "    t_mask = tf.random.uniform([], 0, 100, dtype=tf.int32)\n",
    "    t0 = tf.random.uniform([], 0, 1292 - t_mask, dtype=tf.int32)\n",
    "    mask_t = create_mask(1292, t0, t_mask)\n",
    "    mask_t = tf.reshape(mask_t, [1, 1292, 1])\n",
    "    \n",
    "    mask = mask_f * mask_t\n",
    "    image = image * mask + -80.0 * (1.0 - mask)\n",
    "    return image, label\n",
    "\n",
    "def mixup_data(images, labels):\n",
    "    images = tf.cast(images, tf.float32)\n",
    "    labels = tf.cast(labels, tf.float32)\n",
    "    \n",
    "    lam = tf.random.uniform(shape=[], minval=0.2, maxval=0.8, dtype=tf.float32)\n",
    "    batch_size = tf.shape(images)[0]\n",
    "    indices = tf.random.shuffle(tf.range(batch_size))\n",
    "    \n",
    "    shuffled_images = tf.gather(images, indices)\n",
    "    shuffled_labels = tf.gather(labels, indices)\n",
    "    \n",
    "    mixed_images = lam * images + (1.0 - lam) * shuffled_images\n",
    "    mixed_labels = lam * labels + (1.0 - lam) * shuffled_labels\n",
    "    return mixed_images, mixed_labels\n",
    "\n",
    "class FocalLoss(tf.keras.losses.Loss):\n",
    "    def __init__(self, gamma=2.0, alpha=0.25, **kwargs):\n",
    "        super().__init__(**kwargs)\n",
    "        self.gamma = gamma\n",
    "        self.alpha = alpha\n",
    "\n",
    "    def call(self, y_true, y_pred):\n",
    "        y_pred = tf.clip_by_value(y_pred, 1e-7, 1.0 - 1e-7)\n",
    "        cross_entropy = -y_true * tf.math.log(y_pred)\n",
    "        weight = self.alpha * tf.math.pow(1.0 - y_pred, self.gamma)\n",
    "        loss = weight * cross_entropy\n",
    "        return tf.reduce_sum(loss, axis=-1)\n",
    "\n",
    "class SimpleWandbCallback(tf.keras.callbacks.Callback):\n",
    "    def on_epoch_end(self, epoch, logs=None):\n",
    "        wandb.log(logs)\n",
    "\n",
    "X_train, X_val, y_train, y_val = train_test_split(X, y_encoded_onehot, test_size=0.2, stratify=y_encoded, random_state=42)\n",
    "models_list = []\n",
    "\n",
    "def get_datasets():\n",
    "    train_ds = tf.data.Dataset.from_tensor_slices((X_train, y_train))\n",
    "    train_ds = train_ds.shuffle(1000).map(spec_augment, num_parallel_calls=tf.data.AUTOTUNE)\n",
    "    train_ds = train_ds.batch(16).map(mixup_data, num_parallel_calls=tf.data.AUTOTUNE).prefetch(tf.data.AUTOTUNE)\n",
    "    val_ds = tf.data.Dataset.from_tensor_slices((X_val, y_val)).batch(16).prefetch(tf.data.AUTOTUNE)\n",
    "    return train_ds, val_ds\n",
    "\n",
    "print(\"\\n--- Training Architect 1/3: EffNetV2B0 ---\")\n",
    "K.clear_session()\n",
    "train_dataset, val_dataset = get_datasets()\n",
    "\n",
    "base_1 = EfficientNetV2B0(weights='imagenet', include_top=False, input_shape=(128, 1292, 3))\n",
    "base_1.trainable = True \n",
    "m1 = models.Sequential([\n",
    "    base_1,\n",
    "    layers.GlobalAveragePooling2D(),\n",
    "    layers.Dense(256, activation='relu'),\n",
    "    layers.Dropout(0.4),\n",
    "    layers.Dense(10, activation='softmax')\n",
    "])\n",
    "m1.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=0.0001), loss=tf.keras.losses.CategoricalCrossentropy(label_smoothing=0.1), metrics=['accuracy'])\n",
    "m1.fit(train_dataset, epochs=40, validation_data=val_dataset, callbacks=[SimpleWandbCallback(), ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=3, min_lr=1e-6, verbose=1), EarlyStopping(monitor='val_accuracy', patience=8, restore_best_weights=True, verbose=1)], verbose=1)\n",
    "models_list.append(m1)\n",
    "\n",
    "print(\"\\n--- Training Architect 2/3: EffNetV2B1 + Focal Loss ---\")\n",
    "K.clear_session()\n",
    "train_dataset, val_dataset = get_datasets()\n",
    "\n",
    "base_2 = EfficientNetV2B1(weights='imagenet', include_top=False, input_shape=(128, 1292, 3))\n",
    "base_2.trainable = True \n",
    "m2 = models.Sequential([\n",
    "    base_2,\n",
    "    layers.GlobalAveragePooling2D(),\n",
    "    layers.Dense(256, activation='relu'),\n",
    "    layers.Dropout(0.4),\n",
    "    layers.Dense(10, activation='softmax')\n",
    "])\n",
    "m2.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=0.0002), loss=FocalLoss(), metrics=['accuracy'])\n",
    "m2.fit(train_dataset, epochs=40, validation_data=val_dataset, callbacks=[SimpleWandbCallback(), ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=3, min_lr=1e-6, verbose=1), EarlyStopping(monitor='val_accuracy', patience=8, restore_best_weights=True, verbose=1)], verbose=1)\n",
    "models_list.append(m2)\n",
    "\n",
    "print(\"\\n--- Training Architect 3/3: Hybrid Transformer ---\")\n",
    "K.clear_session()\n",
    "train_dataset, val_dataset = get_datasets()\n",
    "\n",
    "base_3 = EfficientNetV2B0(weights='imagenet', include_top=False, input_shape=(128, 1292, 3))\n",
    "base_3.trainable = True \n",
    "inputs = layers.Input(shape=(128, 1292, 3))\n",
    "x = base_3(inputs)\n",
    "x = layers.Reshape((-1, 1280))(x)\n",
    "attention_output = layers.MultiHeadAttention(num_heads=4, key_dim=256)(x, x)\n",
    "x = layers.Add()([x, attention_output])\n",
    "x = layers.LayerNormalization(epsilon=1e-6)(x)\n",
    "ffn_output = layers.Dense(1280, activation='relu')(x)\n",
    "x = layers.Add()([x, ffn_output])\n",
    "x = layers.LayerNormalization(epsilon=1e-6)(x)\n",
    "x = layers.GlobalAveragePooling1D()(x)\n",
    "x = layers.Dropout(0.4)(x)\n",
    "outputs = layers.Dense(10, activation='softmax')(x)\n",
    "\n",
    "m3 = models.Model(inputs=inputs, outputs=outputs)\n",
    "m3.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=0.0001), loss=tf.keras.losses.CategoricalCrossentropy(label_smoothing=0.1), metrics=['accuracy'])\n",
    "m3.fit(train_dataset, epochs=40, validation_data=val_dataset, callbacks=[SimpleWandbCallback(), ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=3, min_lr=1e-6, verbose=1), EarlyStopping(monitor='val_accuracy', patience=8, restore_best_weights=True, verbose=1)], verbose=1)\n",
    "models_list.append(m3)\n",
    "\n",
    "run.finish()"
