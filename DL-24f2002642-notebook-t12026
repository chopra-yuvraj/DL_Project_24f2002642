    "def build_model(arch='efficientnet_b1', num_classes=10):\n",
    "    if arch == 'efficientnet_b1':\n",
    "        m       = models.efficientnet_b1(weights=models.EfficientNet_B1_Weights.DEFAULT)\n",
    "        in_ftrs = m.classifier[1].in_features\n",
    "        m.classifier = nn.Sequential(\n",
    "            nn.Dropout(0.4),\n",
    "            nn.Linear(in_ftrs, 256),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(256, num_classes)\n",
    "        )\n",
    "    elif arch == 'efficientnet_b0':\n",
    "        m       = models.efficientnet_b0(weights=models.EfficientNet_B0_Weights.DEFAULT)\n",
    "        in_ftrs = m.classifier[1].in_features\n",
    "        m.classifier = nn.Sequential(\n",
    "            nn.Dropout(0.4),\n",
    "            nn.Linear(in_ftrs, 256),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(256, num_classes)\n",
    "        )\n",
    "    elif arch == 'resnet50':\n",
    "        m       = models.resnet50(weights=models.ResNet50_Weights.DEFAULT)\n",
    "        in_ftrs = m.fc.in_features\n",
    "        m.fc    = nn.Sequential(\n",
    "            nn.Dropout(0.4),\n",
    "            nn.Linear(in_ftrs, 512),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(512, num_classes)\n",
    "        )\n",
    "    return m.to(device)\n",
    "\n",
    "\n",
    "def train_one_model(arch, run_name, save_path, lr=1e-4):\n",
    "    model     = build_model(arch)\n",
    "    criterion = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
    "    optimizer = optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-2)\n",
    "    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=EPOCHS, eta_min=1e-6)\n",
    "\n",
    "    run = wandb.init(\n",
    "        entity   = 'choprayuvraj-iit-madras',\n",
    "        project  = '24f2002642-t12026',\n",
    "        name     = run_name,\n",
    "        job_type = 'train',\n",
    "        config   = {'arch': arch, 'epochs': EPOCHS, 'lr': lr, 'batch': BATCH}\n",
    "    )\n",
    "\n",
    "    best_f1 = 0.0\n",
    "\n",
    "    for epoch in range(EPOCHS):\n",
    "        model.train()\n",
    "        tr_loss, tr_preds, tr_true = 0.0, [], []\n",
    "\n",
    "        for specs, labels in tqdm(train_loader, desc=f'{arch} Ep {epoch+1}/{EPOCHS}', leave=False):\n",
    "            specs, labels = specs.to(device), labels.to(device)\n",
    "            optimizer.zero_grad()\n",
    "            out  = model(specs)\n",
    "            loss = criterion(out, labels)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "            tr_loss += loss.item() * specs.size(0)\n",
    "            tr_preds.extend(out.argmax(1).cpu().numpy())\n",
    "            tr_true.extend(labels.cpu().numpy())\n",
    "\n",
    "        model.eval()\n",
    "        val_loss, val_preds, val_true = 0.0, [], []\n",
    "        with torch.no_grad():\n",
    "            for specs, labels in val_loader:\n",
    "                specs, labels = specs.to(device), labels.to(device)\n",
    "                out  = model(specs)\n",
    "                loss = criterion(out, labels)\n",
    "                val_loss += loss.item() * specs.size(0)\n",
    "                val_preds.extend(out.argmax(1).cpu().numpy())\n",
    "                val_true.extend(labels.cpu().numpy())\n",
    "\n",
    "        scheduler.step()\n",
    "\n",
    "        t_f1  = f1_score(tr_true,  tr_preds,  average='macro', zero_division=0)\n",
    "        v_f1  = f1_score(val_true, val_preds, average='macro', zero_division=0)\n",
    "        t_acc = (np.array(tr_preds) == np.array(tr_true)).mean()\n",
    "        v_acc = (np.array(val_preds) == np.array(val_true)).mean()\n",
    "\n",
    "        wandb.log({\n",
    "            'epoch': epoch + 1,\n",
    "            'train_loss': tr_loss / len(train_ds), 'val_loss': val_loss / len(val_ds),\n",
    "            'train_acc': t_acc, 'val_acc': v_acc,\n",
    "            'train_f1': t_f1,   'val_f1': v_f1,\n",
    "            'lr': optimizer.param_groups[0]['lr']\n",
    "        })\n",
    "\n",
    "        print(f'[{arch}] Ep {epoch+1:02d} | trn acc={t_acc:.3f} f1={t_f1:.3f} | val acc={v_acc:.3f} f1={v_f1:.3f}')\n",
    "\n",
    "        if v_f1 > best_f1:\n",
    "            best_f1 = v_f1\n",
    "            torch.save(model.state_dict(), save_path)\n",
    "\n",
    "    wandb.finish()\n",
    "    print(f'[{arch}] Best Val F1: {best_f1:.4f}')\n",
    "\n",
    "    del model, optimizer, scheduler\n",
    "    torch.cuda.empty_cache()\n",
    "    gc.collect()\n",
    "\n",
    "    return best_f1"
   ]
