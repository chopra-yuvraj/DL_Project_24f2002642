    "test_df = pd.read_csv(TEST_CSV)\n",
    "\n",
    "id_to_file = {}\n",
    "for f in os.listdir(TEST_DIR):\n",
    "    if f.endswith('.wav'):\n",
    "        digits = ''.join(filter(str.isdigit, f))\n",
    "        if digits:\n",
    "            id_to_file[int(digits)] = f\n",
    "\n",
    "model.load_state_dict(torch.load('/kaggle/working/best_model.pth', map_location=device))\n",
    "model.eval()\n",
    "\n",
    "freq_mask = T.FrequencyMasking(freq_mask_param=15)\n",
    "time_mask = T.TimeMasking(time_mask_param=60)\n",
    "\n",
    "\n",
    "def tta_predict(spec_np):\n",
    "    spec  = torch.tensor(spec_np).unsqueeze(0)\n",
    "    versions = [spec.clone()]\n",
    "    for _ in range(3):\n",
    "        aug = time_mask(freq_mask(spec.clone()))\n",
    "        versions.append(aug)\n",
    "\n",
    "    prob_sum = None\n",
    "    for v in versions:\n",
    "        inp = v.repeat(3, 1, 1).unsqueeze(0).to(device)\n",
    "        with torch.no_grad():\n",
    "            p = torch.softmax(model(inp), dim=1)\n",
    "        prob_sum = p if prob_sum is None else prob_sum + p\n",
    "\n",
    "    return (prob_sum / len(versions)).argmax(1).item()\n",
    "\n",
    "\n",
    "rows = []\n",
    "for _, row in tqdm(test_df.iterrows(), total=len(test_df)):\n",
    "    sid   = row['id']\n",
    "    fname = id_to_file.get(sid)\n",
    "    label = 'pop'\n",
    "    if fname:\n",
    "        try:\n",
    "            y, _ = librosa.load(os.path.join(TEST_DIR, fname), sr=SR, duration=30)\n",
    "            spec  = get_mel_spec(y)\n",
    "            spec  = (spec - X_mean) / X_std\n",
    "            label = label_encoder.inverse_transform([tta_predict(spec)])[0]\n",
    "        except Exception:\n",
    "            pass\n",
    "    rows.append([sid, label])\n",
    "\n",
    "submission = pd.DataFrame(rows, columns=['id', 'genre'])\n",
    "submission.to_csv('/kaggle/working/submission.csv', index=False)\n",
    "print(submission['genre'].value_counts())"
   ]
