    "\n",
    "for idx in tqdm(range(len(test_df)), desc='Inference'):\n",
    "    song_id = int(test_df.iloc[idx]['id'])\n",
    "    fname   = id_to_file.get(song_id)\n",
    "\n",
    "    try:\n",
    "        wav, sr = torchaudio.load(os.path.join(MASHUPS_PATH, fname))\n",
    "        if wav.shape[0] > 1:\n",
    "            wav = wav.mean(dim=0, keepdim=True)\n",
    "        if sr != SR:\n",
    "            wav = AT.Resample(sr, SR)(wav)\n",
    "        audio = wav.squeeze(0).numpy().astype(np.float32)\n",
    "        audio = audio / (np.max(np.abs(audio)) + 1e-6)\n",
    "\n",
    "        all_probs = []\n",
    "        for tta_i in range(N_TTA):\n",
    "            clip = crop_random(audio)\n",
