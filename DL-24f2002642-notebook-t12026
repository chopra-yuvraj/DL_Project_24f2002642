    "STEMS_PATH = None\n",
    "for root, dirs, files in os.walk('/kaggle/input'):\n",
    "    if 'genres_stems' in dirs:\n",
    "        STEMS_PATH = os.path.join(root, 'genres_stems')\n",
    "        break\n",
    "\n",
    "if not STEMS_PATH:\n",
    "    raise FileNotFoundError(\"Dataset not found.\")\n",
    "\n",
    "train_data = []\n",
    "genres = os.listdir(STEMS_PATH)\n",
    "\n",
    "for genre in genres:\n",
    "    genre_path = os.path.join(STEMS_PATH, genre)\n",
    "    if os.path.isdir(genre_path):\n",
    "        song_folders = os.listdir(genre_path)\n",
    "        for song in tqdm(song_folders, desc=f\"Indexing {genre}\"):\n",
    "            song_path = os.path.join(genre_path, song)\n",
    "            stems = [os.path.join(song_path, s) for s in os.listdir(song_path) if s.endswith('.wav')]\n",
    "            if stems:\n",
    "                train_data.append((stems, genre))\n",
    "\n",
    "df = pd.DataFrame(train_data, columns=['stem_paths', 'genre'])\n",
    "\n",
    "label_encoder = LabelEncoder()\n",
    "df['label'] = label_encoder.fit_transform(df['genre'])\n",
    "\n",
    "train_df, val_df = train_test_split(df, test_size=0.2, stratify=df['label'], random_state=42)\n",
    "train_df = train_df.reset_index(drop=True)\n",
    "val_df = val_df.reset_index(drop=True)"
   ]
