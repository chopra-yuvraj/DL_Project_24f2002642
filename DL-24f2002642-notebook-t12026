    "run = wandb.init(\n",
    "    entity=\"choprayuvraj-iit-madras\",\n",
    "    project=\"24f2002642-t12026\",\n",
    "    name=\"EffNetB2 High Res with Batch Size 8\",\n",
    "    job_type=\"train\"\n",
    ")\n",
    "\n",
    "label_encoder = LabelEncoder()\n",
    "y_encoded = label_encoder.fit_transform(y_target)\n",
    "y_encoded_onehot = tf.keras.utils.to_categorical(y_encoded, num_classes=10).astype(np.float32)\n",
    "\n",
    "def create_mask(shape, start, size):\n",
    "    indices = tf.range(shape)\n",
    "    mask = tf.logical_or(indices < start, indices >= start + size)\n",
    "    return tf.cast(mask, tf.float32)\n",
    "\n",
    "def spec_augment(image, label):\n",
    "    image = tf.cast(image, tf.float32)\n",
    "    label = tf.cast(label, tf.float32)\n",
    "    \n",
    "    f_mask = tf.random.uniform([], 0, 40, dtype=tf.int32)\n",
    "    f0 = tf.random.uniform([], 0, 256 - f_mask, dtype=tf.int32)\n",
    "    mask_f = create_mask(256, f0, f_mask)\n",
    "    mask_f = tf.reshape(mask_f, [256, 1, 1])\n",
    "    \n",
    "    t_mask = tf.random.uniform([], 0, 100, dtype=tf.int32)\n",
    "    t0 = tf.random.uniform([], 0, 1292 - t_mask, dtype=tf.int32)\n",
    "    mask_t = create_mask(1292, t0, t_mask)\n",
    "    mask_t = tf.reshape(mask_t, [1, 1292, 1])\n",
    "    \n",
    "    mask = mask_f * mask_t\n",
    "    image = image * mask + -80.0 * (1.0 - mask)\n",
    "    return image, label\n",
    "\n",
    "def mixup_data(images, labels):\n",
    "    images = tf.cast(images, tf.float32)\n",
    "    labels = tf.cast(labels, tf.float32)\n",
    "    \n",
    "    lam = tf.random.uniform(shape=[], minval=0.2, maxval=0.8, dtype=tf.float32)\n",
    "    batch_size = tf.shape(images)[0]\n",
    "    indices = tf.random.shuffle(tf.range(batch_size))\n",
    "    \n",
    "    shuffled_images = tf.gather(images, indices)\n",
    "    shuffled_labels = tf.gather(labels, indices)\n",
    "    \n",
    "    mixed_images = lam * images + (1.0 - lam) * shuffled_images\n",
    "    mixed_labels = lam * labels + (1.0 - lam) * shuffled_labels\n",
    "    return mixed_images, mixed_labels\n",
    "\n",
    "class SimpleWandbCallback(tf.keras.callbacks.Callback):\n",
    "    def on_epoch_end(self, epoch, logs=None):\n",
    "        wandb.log(logs)\n",
    "\n",
    "skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "models_list = []\n",
    "\n",
    "for fold, (train_idx, val_idx) in enumerate(skf.split(X, y_encoded)):\n",
    "    print(f\"\\n--- Training Fold {fold + 1}/5 ---\")\n",
    "    K.clear_session()\n",
    "    \n",
    "    X_train, X_val = X[train_idx], X[val_idx]\n",
    "    y_train, y_val = y_encoded_onehot[train_idx], y_encoded_onehot[val_idx]\n",
    "    \n",
    "    train_dataset = tf.data.Dataset.from_tensor_slices((X_train, y_train))\n",
    "    train_dataset = train_dataset.shuffle(1000).map(spec_augment, num_parallel_calls=tf.data.AUTOTUNE)\n",
    "    train_dataset = train_dataset.batch(8).map(mixup_data, num_parallel_calls=tf.data.AUTOTUNE).prefetch(tf.data.AUTOTUNE)\n",
    "\n",
    "    val_dataset = tf.data.Dataset.from_tensor_slices((X_val, y_val)).batch(8).prefetch(tf.data.AUTOTUNE)\n",
    "\n",
    "    base_model = EfficientNetB2(weights='imagenet', include_top=False, input_shape=(256, 1292, 3))\n",
    "    base_model.trainable = True \n",
    "\n",
    "    model = models.Sequential([\n",
    "        base_model,\n",
    "        layers.GlobalAveragePooling2D(),\n",
    "        layers.Dropout(0.5),\n",
    "        layers.Dense(10, activation='softmax')\n",
    "    ])\n",
    "\n",
    "    optimizer = tf.keras.optimizers.Adam(learning_rate=0.0001)"
   ]
