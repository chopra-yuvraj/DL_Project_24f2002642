    "class AudioStemDataset(Dataset):\n",
    "    def __init__(self, dataframe, target_sr=22050, max_duration=30):\n",
    "        self.dataframe = dataframe\n",
    "        self.target_sr = target_sr\n",
    "        self.max_length = target_sr * max_duration\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.dataframe)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        row = self.dataframe.iloc[idx]\n",
    "        stem_paths = row['stem_paths']\n",
    "        label = row['label']\n",
    "\n",
    "        mixed_waveform = None\n",
    "        for path in stem_paths:\n",
    "            waveform, sr = torchaudio.load(path)\n",
    "            if sr != self.target_sr:\n",
    "                resampler = T.Resample(sr, self.target_sr)\n",
    "                waveform = resampler(waveform)\n",
    "            \n",
    "            if waveform.shape[0] > 1:\n",
    "                waveform = torch.mean(waveform, dim=0, keepdim=True)\n",
    "                \n",
    "            if mixed_waveform is None:\n",
    "                mixed_waveform = waveform\n",
    "            else:\n",
    "                min_len = min(mixed_waveform.shape[1], waveform.shape[1])\n",
    "                mixed_waveform = mixed_waveform[:, :min_len] + waveform[:, :min_len]\n",
    "\n",
    "        if mixed_waveform is None:\n",
    "            mixed_waveform = torch.zeros((1, self.max_length))\n",
    "\n",
    "        if mixed_waveform.shape[1] < self.max_length:\n",
    "            pad_amount = self.max_length - mixed_waveform.shape[1]\n",
    "            mixed_waveform = torch.nn.functional.pad(mixed_waveform, (0, pad_amount))\n",
    "        else:\n",
    "            mixed_waveform = mixed_waveform[:, :self.max_length]\n",
    "            \n",
    "        mixed_waveform = mixed_waveform / (torch.max(torch.abs(mixed_waveform)) + 1e-6)\n",
    "\n",
    "        return mixed_waveform, torch.tensor(label, dtype=torch.long)\n",
    "\n",
    "train_dataset = AudioStemDataset(train_df)\n",
    "val_dataset = AudioStemDataset(val_df)\n",
    "\n",
    "train_loader = DataLoader(train_dataset, batch_size=16, shuffle=True, num_workers=2, pin_memory=True)\n",
    "val_loader = DataLoader(val_dataset, batch_size=16, shuffle=False, num_workers=2, pin_memory=True)"
   ]
