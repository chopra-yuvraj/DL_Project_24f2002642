    "class DynamicAudioDataset(Dataset):\n",
    "    def __init__(self, dataframe, noises, is_train=True, target_sr=22050, duration=30):\n",
    "        self.dataframe = dataframe\n",
    "        self.noises = noises\n",
    "        self.is_train = is_train\n",
    "        self.target_length = target_sr * duration\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.dataframe)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        row = self.dataframe.iloc[idx]\n",
    "        waveform, _ = torchaudio.load(row['file_path'])\n",
    "        \n",
    "        if self.is_train and len(self.noises) > 0 and random.random() > 0.3:\n",
    "            noise = random.choice(self.noises)\n",
    "            \n",
    "            if noise.shape[1] > self.target_length:\n",
    "                noise = noise[:, :self.target_length]\n",
    "                \n",
    "            start_idx = random.randint(0, self.target_length - noise.shape[1])\n",
    "            intensity = random.uniform(0.05, 0.3)\n",
    "            \n",
    "            waveform[:, start_idx:start_idx + noise.shape[1]] += (noise * intensity)\n",
    "            waveform = waveform / (torch.max(torch.abs(waveform)) + 1e-6)\n",
    "\n",
    "        return waveform, torch.tensor(row['label'], dtype=torch.long)\n",
    "\n",
    "train_dataset = DynamicAudioDataset(train_df, loaded_noises, is_train=True)\n",
    "val_dataset = DynamicAudioDataset(val_df, loaded_noises, is_train=False)\n",
    "\n",
    "train_loader = DataLoader(train_dataset, batch_size=16, shuffle=True, num_workers=2, pin_memory=True)\n",
    "val_loader = DataLoader(val_dataset, batch_size=16, shuffle=False, num_workers=2, pin_memory=True)"
   ]
