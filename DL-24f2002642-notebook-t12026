    "def load_and_mix(song_path):\n",
    "    mixed = None\n",
    "    for stem in STEMS:\n",
    "        path  = os.path.join(song_path, stem)\n",
    "        audio, _ = librosa.load(path, sr=SAMPLE_RATE, mono=True)\n",
    "        audio = audio.astype(np.float32)\n",
    "        mixed = audio if mixed is None else mixed + audio\n",
    "    mixed = mixed / (np.max(np.abs(mixed)) + 1e-6)\n",
    "    return mixed\n",
    "\n",
    "\n",
    "def random_crop(audio):\n",
    "    if len(audio) >= MAX_LENGTH:\n",
    "        start = random.randint(0, len(audio) - MAX_LENGTH)\n",
    "        return audio[start: start + MAX_LENGTH]\n",
    "    return np.pad(audio, (0, MAX_LENGTH - len(audio)))\n",
    "\n",
    "\n",
    "def extract_features(audio, sr=SAMPLE_RATE):\n",
    "    feats = []\n",
    "\n",
    "    mfcc = librosa.feature.mfcc(y=audio, sr=sr, n_mfcc=N_MFCC)\n",
    "    feats.extend(mfcc.mean(axis=1).tolist())\n",
    "    feats.extend(mfcc.std(axis=1).tolist())\n",
    "\n",
    "    chroma = librosa.feature.chroma_stft(y=audio, sr=sr, n_chroma=N_CHROMA)\n",
    "    feats.extend(chroma.mean(axis=1).tolist())\n",
    "    feats.extend(chroma.std(axis=1).tolist())\n",
    "\n",
    "    contrast = librosa.feature.spectral_contrast(y=audio, sr=sr)\n",
    "    feats.extend(contrast.mean(axis=1).tolist())\n",
    "    feats.extend(contrast.std(axis=1).tolist())\n",
    "\n",
    "    rms = librosa.feature.rms(y=audio)\n",
    "    feats.append(float(rms.mean()))\n",
    "    feats.append(float(rms.std()))\n",
    "\n",
    "    zcr = librosa.feature.zero_crossing_rate(y=audio)\n",
    "    feats.append(float(zcr.mean()))\n",
    "    feats.append(float(zcr.std()))\n",
    "\n",
    "    rolloff = librosa.feature.spectral_rolloff(y=audio, sr=sr)\n",
    "    feats.append(float(rolloff.mean()))\n",
    "    feats.append(float(rolloff.std()))\n",
    "\n",
    "    return np.array(feats, dtype=np.float32)\n",
    "\n",
    "\n",
    "print(f'Feature vector size: {len(extract_features(np.zeros(MAX_LENGTH)))}')"
   ]
