    "def mixup_batch(waveforms, labels, alpha=0.4):\n",
    "    lam   = np.random.beta(alpha, alpha) if alpha > 0 else 1.0\n",
    "    idx   = torch.randperm(waveforms.size(0), device=waveforms.device)\n",
    "    mixed = lam * waveforms + (1 - lam) * waveforms[idx]\n",
    "    return mixed, labels, labels[idx], lam\n",
    "\n",
    "\n",
    "def mixup_criterion(criterion, pred, y_a, y_b, lam):\n",
    "    return lam * criterion(pred, y_a) + (1 - lam) * criterion(pred, y_b)\n",
    "\n",
    "\n",
    "run = wandb.init(\n",
    "    entity  = 'choprayuvraj-iit-madras',\n",
    "    project = '24f2002642-t12026',\n",
    "    name    = 'RAM-Cache EfficientNet-B1 Progressive Unfreeze v3',\n",
    "    config  = {\n",
    "        'epochs'          : EPOCHS,\n",
    "        'unfreeze_epoch'  : UNFREEZE_EPOCH,\n",
    "        'batch_size'      : BATCH_SIZE,\n",
    "        'warmup_lr'       : WARMUP_LR,\n",
    "        'finetune_lr'     : FINETUNE_LR,\n",
    "        'weight_decay'    : WEIGHT_DECAY,\n",
    "        'label_smoothing' : LABEL_SMOOTHING,\n",
    "        'n_mels'          : N_MELS,\n",
    "        'n_fft'           : N_FFT,\n",
    "        'hop_length'      : HOP_LENGTH,\n",
    "        'architecture'    : 'EfficientNet-B1',\n",
    "        'tta_versions'    : 5,\n",
    "        'mixup_alpha'     : 0.4,\n",
    "        'spec_normalize'  : True,\n",
    "    },\n",
    "    job_type = 'train'\n",
    ")\n",
    "\n",
    "best_val_f1  = 0.0\n",
    "best_val_acc = 0.0\n",
    "\n",
    "print(f'Starting training for {EPOCHS} epochs...')\n",
    "print(f'  Phase 1 (frozen backbone) : epochs 1 – {UNFREEZE_EPOCH}')\n",
    "print(f'  Phase 2 (full fine-tune)  : epochs {UNFREEZE_EPOCH+1} – {EPOCHS}')\n",
    "print('-' * 70)\n",
    "\n",
    "for epoch in range(EPOCHS):\n",
    "\n",
    "    if epoch == UNFREEZE_EPOCH:\n",
    "        model.unfreeze_backbone()\n",
    "        optimizer = optim.AdamW(\n",
    "            model.parameters(), lr=FINETUNE_LR, weight_decay=WEIGHT_DECAY\n",
    "        )\n",
    "        scheduler = optim.lr_scheduler.CosineAnnealingLR(\n",
    "            optimizer, T_max=(EPOCHS - UNFREEZE_EPOCH), eta_min=1e-6\n",
    "        )\n",
    "\n",
    "    model.train()\n",
    "    run_loss, correct, total = 0.0, 0, 0\n",
    "    all_preds, all_labels_ep = [], []\n",
    "\n",
    "    pbar = tqdm(train_loader, desc=f'Epoch {epoch+1:02d}/{EPOCHS} [TRN]', leave=False)\n",
    "    for waveforms, labels in pbar:\n",
    "        waveforms = waveforms.to(device)\n",
    "        labels    = labels.to(device)\n",
    "\n",
    "        use_mixup = random.random() < 0.5\n",
    "        if use_mixup:\n",
    "            waveforms, labels_a, labels_b, lam = mixup_batch(waveforms, labels)\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "        with autocast():\n",
    "            outputs = model(waveforms, augment=True)\n",
    "            if use_mixup:\n",
    "                loss = mixup_criterion(criterion, outputs, labels_a, labels_b, lam)\n",
    "            else:\n",
    "                loss = criterion(outputs, labels)\n",
    "\n",
    "        scaler.scale(loss).backward()\n",
    "        scaler.unscale_(optimizer)\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
    "        scaler.step(optimizer)\n",
    "        scaler.update()\n",
    "\n",
    "        run_loss += loss.item() * waveforms.size(0)\n",
    "        preds     = outputs.argmax(1)\n",
    "        true_labels = labels_a if use_mixup else labels\n",
    "        correct += preds.eq(true_labels).sum().item()\n",
    "        total   += true_labels.size(0)\n",
    "        all_preds.extend(preds.cpu().numpy())\n",
    "        all_labels_ep.extend(true_labels.cpu().numpy())\n",
    "        pbar.set_postfix(loss=f'{loss.item():.4f}', acc=f'{correct/total:.3f}')\n",
    "\n",
    "    train_loss = run_loss / total\n",
    "    train_acc  = correct / total\n",
    "    train_f1   = f1_score(all_labels_ep, all_preds, average='macro', zero_division=0)\n",
    "\n",
    "    model.eval()\n",
    "    v_loss, v_correct, v_total = 0.0, 0, 0\n",
    "    v_preds, v_labels = [], []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for waveforms, labels in tqdm(val_loader, desc=f'Epoch {epoch+1:02d}/{EPOCHS} [VAL]', leave=False):\n",
    "            waveforms = waveforms.to(device)\n",
    "            labels    = labels.to(device)\n",
    "            with autocast():\n",
    "                outputs = model(waveforms, augment=False)\n",
    "                loss    = criterion(outputs, labels)\n",
    "            v_loss    += loss.item() * waveforms.size(0)\n",
    "            preds      = outputs.argmax(1)\n",
    "            v_correct += preds.eq(labels).sum().item()\n",
    "            v_total   += labels.size(0)\n",
    "            v_preds.extend(preds.cpu().numpy())\n",
    "            v_labels.extend(labels.cpu().numpy())\n",
    "\n",
    "    val_loss = v_loss / v_total\n",
    "    val_acc  = v_correct / v_total\n",
    "    val_f1   = f1_score(v_labels, v_preds, average='macro', zero_division=0)\n",
    "\n",
    "    scheduler.step()\n",
    "    current_lr = optimizer.param_groups[0]['lr']\n",
    "\n",
    "    wandb.log({\n",
    "        'epoch'     : epoch + 1,\n",
    "        'train_loss': train_loss, 'train_acc': train_acc, 'train_f1': train_f1,\n",
    "        'val_loss'  : val_loss,   'val_acc'  : val_acc,   'val_f1'  : val_f1,\n",
    "        'lr'        : current_lr,\n",
    "    })\n",
    "\n",
    "    flag = ''\n",
    "    if val_f1 > best_val_f1:\n",
    "        best_val_f1  = val_f1\n",
    "        best_val_acc = val_acc\n",
    "        torch.save(model.state_dict(), os.path.join(OUTPUT_DIR, 'best_model.pth'))\n",
    "        flag = '  ✓ BEST SAVED'\n",
    "\n",
    "    print(f'Ep {epoch+1:02d} | '\n",
    "          f'Trn  loss={train_loss:.4f} acc={train_acc:.3f} F1={train_f1:.3f} | '\n",
    "          f'Val  loss={val_loss:.4f} acc={val_acc:.3f} F1={val_f1:.3f} | '\n",
    "          f'lr={current_lr:.2e}{flag}')\n",
    "\n",
    "wandb.finish()\n",
    "print(f'\\nTraining complete — Best Val F1: {best_val_f1:.4f}  |  Best Val Acc: {best_val_acc:.4f}')\n"
   ]
