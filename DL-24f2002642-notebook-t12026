    "class RAMAudioDataset(Dataset):\n",
    "\n",
    "    def __init__(self, indices, waveform_data, noise_list, label_encoder, is_train=True):\n",
    "        self.indices  = indices\n",
    "        self.data     = waveform_data\n",
    "        self.noises   = noise_list\n",
    "        self.le       = label_encoder\n",
    "        self.is_train = is_train\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.indices)\n",
    "\n",
    "    def _inject_noise(self, wf):\n",
    "        if not self.noises or random.random() > 0.65:\n",
    "            return wf\n",
    "        noise = random.choice(self.noises).clone()\n",
    "        if noise.shape[1] < TARGET_LENGTH:\n",
    "            reps  = (TARGET_LENGTH // noise.shape[1]) + 1\n",
    "            noise = noise.repeat(1, reps)\n",
    "        start = random.randint(0, noise.shape[1] - TARGET_LENGTH)\n",
    "        noise = noise[:, start:start + TARGET_LENGTH]\n",
    "        intensity = random.uniform(0.04, 0.25)\n",
    "        wf = wf + noise * intensity\n",
    "        peak = torch.max(torch.abs(wf))\n",
    "        if peak > 1e-6:\n",
    "            wf = wf / peak\n",
    "        return wf\n",
    "\n",
    "    def _gain_jitter(self, wf):\n",
    "        if random.random() > 0.5:\n",
    "            gain = random.uniform(0.5, 1.5)\n",
    "            wf   = wf * gain\n",
    "            peak = torch.max(torch.abs(wf))\n",
    "            if peak > 1e-6:\n",
    "                wf = wf / peak\n",
    "        return wf\n",
    "\n",
    "    def _random_shift(self, wf):\n",
    "        if random.random() > 0.5:\n",
    "            shift = random.randint(0, TARGET_SR * 2)\n",
    "            wf    = torch.roll(wf, shift, dims=1)\n",
    "        return wf\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        real_idx          = self.indices[idx]\n",
    "        waveform, genre   = self.data[real_idx]\n",
    "        waveform          = waveform.clone()\n",
    "        label             = self.le.transform([genre])[0]\n",
    "\n",
    "        if self.is_train:\n",
    "            waveform = self._inject_noise(waveform)\n",
    "            waveform = self._gain_jitter(waveform)\n",
    "            waveform = self._random_shift(waveform)\n",
    "\n",
    "        return waveform, torch.tensor(label, dtype=torch.long)\n",
    "\n",
    "\n",
    "train_dataset = RAMAudioDataset(train_idx, train_waveforms, noise_waveforms, label_encoder, is_train=True)\n",
    "val_dataset   = RAMAudioDataset(val_idx,   train_waveforms, noise_waveforms, label_encoder, is_train=False)\n",
    "\n",
    "train_loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True,  num_workers=2, pin_memory=True)\n",
