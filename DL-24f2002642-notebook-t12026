    "\n",
    "actual_files = os.listdir(test_dir)\n",
    "id_to_filename = {}\n",
    "for filename in actual_files:\n",
    "    if not filename.endswith('.wav'): continue\n",
    "    digits = ''.join(filter(str.isdigit, filename))\n",
    "    if digits:\n",
    "        id_to_filename[int(digits)] = filename\n",
    "\n",
    "submission_data = []\n",
    "\n",
    "for index, row in tqdm(test_df.iterrows(), total=len(test_df)):\n",
    "    song_id = row['id']\n",
    "    filename = id_to_filename.get(song_id)\n",
    "    \n",
    "    if filename:\n",
    "        file_path = os.path.join(test_dir, filename)\n",
    "        try:\n",
    "            audio_y, sr = librosa.load(file_path, duration=30)\n",
    "            chunk_length = 10 * sr\n",
    "            song_probs = []\n",
    "            \n",
    "            for i in range(3):\n",
    "                start = i * int(chunk_length)\n",
    "                end = start + int(chunk_length)\n",
    "                chunk = audio_y[start:end]\n",
    "                \n",
    "                if len(chunk) < int(chunk_length):\n",
    "                    chunk = np.pad(chunk, (0, int(chunk_length) - len(chunk)), mode='constant')\n",
    "                \n",
    "                img = get_spectrogram(chunk, sr)\n",
    "                if img is not None:\n",
    "                    img_3c = np.stack((img,)*3, axis=-1)\n",
    "                    img_input = img_3c[np.newaxis, ...]\n",
    "                    \n",
    "                    noise = np.random.normal(0, 0.05, img_input.shape).astype(np.float32)\n",
    "                    img_noise = img_input + noise\n",
    "                    \n",
    "                    for m in models_list:\n",
    "                        p1 = m.predict(img_input, verbose=0)\n",
    "                        p2 = m.predict(img_noise, verbose=0)\n",
    "                        song_probs.append((p1 + p2) / 2.0)\n",
    "            \n",
    "            if len(song_probs) > 0:\n",
    "                avg_probs = np.mean(song_probs, axis=0)\n",
    "                pred_num = np.argmax(avg_probs)\n",
    "                pred_label = label_encoder.inverse_transform([pred_num])[0]\n",
    "                submission_data.append([song_id, pred_label])\n",
