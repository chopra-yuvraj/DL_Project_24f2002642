    "skf     = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "oof_f1s = []\n",
    "models  = []\n",
    "\n",
    "for fold, (tr_idx, va_idx) in enumerate(skf.split(X_train, y_train)):\n",
    "    X_tr, X_va = X_train[tr_idx], X_train[va_idx]\n",
    "    y_tr, y_va = y_train[tr_idx], y_train[va_idx]\n",
    "\n",
    "    dtrain = lgb.Dataset(X_tr, label=y_tr)\n",
    "    dval   = lgb.Dataset(X_va, label=y_va, reference=dtrain)\n",
    "\n",
    "    model = lgb.train(\n",
    "        params,\n",
    "        dtrain,\n",
    "        num_boost_round      = 500,\n",
    "        valid_sets           = [dval],\n",
    "        callbacks            = [\n",
    "            lgb.early_stopping(stopping_rounds=30, verbose=False),\n",
    "            lgb.log_evaluation(period=50)\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    preds = model.predict(X_va) \n",
    "    pred_labels = np.argmax(preds, axis=1)\n",
    "    f1  = f1_score(y_va, pred_labels, average='macro')\n",
    "    oof_f1s.append(f1)\n",
    "    models.append(model)\n",
    "\n",
    "    wandb.log({'fold': fold + 1, 'val_f1': f1})\n",
    "    print(f'Fold {fold+1} | val macro F1 = {f1:.4f} | best iter = {model.best_iteration}')\n",
    "\n",
    "mean_f1 = np.mean(oof_f1s)\n",
    "wandb.log({'cv_mean_f1': mean_f1})\n",
    "print(f'\\nCV mean macro F1: {mean_f1:.4f}')"
   ]
