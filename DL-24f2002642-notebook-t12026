    "class SpecNormalize(nn.Module):\n",
    "       def forward(self, x):\n",
    "        mean = x.mean(dim=(-2, -1), keepdim=True)\n",
    "        std  = x.std(dim=(-2, -1),  keepdim=True) + 1e-6\n",
    "        return (x - mean) / std\n",
    "\n",
    "\n",
    "class TransferAudioCNN(nn.Module):\n",
    "    def __init__(self, num_classes=NUM_CLASSES):\n",
    "        super().__init__()\n",
    "\n",
    "        self.mel       = T.MelSpectrogram(\n",
    "            sample_rate=TARGET_SR, n_mels=N_MELS,\n",
    "            n_fft=N_FFT, hop_length=HOP_LENGTH,\n",
    "            f_min=20.0, f_max=8000.0\n",
    "        )\n",
    "        self.amp_to_db = T.AmplitudeToDB(top_db=80)\n",
    "        self.spec_norm = SpecNormalize()\n",
    "\n",
    "        self.freq_mask = T.FrequencyMasking(freq_mask_param=20)\n",
    "        self.time_mask = T.TimeMasking(time_mask_param=60)\n",
    "\n",
    "        self.backbone = models.efficientnet_b1(\n",
    "            weights=models.EfficientNet_B1_Weights.DEFAULT\n",
    "        )\n",
    "\n",
    "        for param in self.backbone.features.parameters():\n",
    "            param.requires_grad = False\n",
    "\n",
    "        in_ftrs = self.backbone.classifier[1].in_features\n",
    "        self.backbone.classifier = nn.Sequential(\n",
    "            nn.Dropout(p=0.4),\n",
    "            nn.Linear(in_ftrs, 512),\n",
    "            nn.BatchNorm1d(512),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(p=0.25),\n",
    "            nn.Linear(512, num_classes)\n",
    "        )\n",
    "\n",
    "    def unfreeze_backbone(self):\n",
    "        for param in self.backbone.features.parameters():\n",
    "            param.requires_grad = True\n",
    "        print('  >> Backbone unfrozen — fine-tuning all layers.')\n",
    "\n",
    "    def forward(self, x, augment=False):\n",
    "        with torch.no_grad():\n",
    "            x = self.mel(x)        \n",
    "            x = self.amp_to_db(x)  \n",
    "\n",
    "        x = self.spec_norm(x)      \n",
    "\n",
    "        if augment and self.training:\n",
    "            x = self.freq_mask(x)\n",
    "            x = self.time_mask(x)\n",
    "\n",
    "        x = x.repeat(1, 3, 1, 1)  \n",
    "        return self.backbone(x)\n",
