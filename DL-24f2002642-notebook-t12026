    "def load_mix(song_path):\n",
    "    mixed = None\n",
    "    for stem in STEMS:\n",
    "        wav, sr = torchaudio.load(os.path.join(song_path, stem))\n",
    "        if wav.shape[0] > 1:\n",
    "            wav = wav.mean(dim=0, keepdim=True)\n",
    "        if sr != SR:\n",
    "            wav = AT.Resample(sr, SR)(wav)\n",
    "        arr   = wav.squeeze(0).numpy().astype(np.float32)\n",
    "        mixed = arr if mixed is None else mixed + arr\n",
    "    peak = np.max(np.abs(mixed)) + 1e-6\n",
    "    return mixed / peak\n",
    "\n",
    "\n",
    "def crop_random(audio):\n",
    "    if len(audio) >= TARGET_LENGTH:\n",
    "        start = random.randint(0, len(audio) - TARGET_LENGTH)\n",
    "        return audio[start: start + TARGET_LENGTH]\n",
    "    return np.pad(audio, (0, TARGET_LENGTH - len(audio)))\n",
    "\n",
    "\n",
    "def crop_center(audio):\n",
    "    if len(audio) >= TARGET_LENGTH:\n",
    "        start = (len(audio) - TARGET_LENGTH) // 2\n",
    "        return audio[start: start + TARGET_LENGTH]\n",
    "    return np.pad(audio, (0, TARGET_LENGTH - len(audio)))\n",
    "\n",
    "\n",
    "class TrainDataset(Dataset):\n",
    "    def __init__(self, index, size=TRAIN_SIZE):\n",
    "        self.index = index\n",
    "        self.size  = size\n",
    "\n",
    "    def __len__(self):\n",
    "        return self.size\n",
    "\n",
    "    def __getitem__(self, _):\n",
    "        while True:\n",
    "            try:\n",
    "                genre     = random.choice(GENRES)\n",
    "                song_path = random.choice(self.index[genre])\n",
    "                audio     = load_mix(song_path)\n",
    "                audio     = crop_random(audio)\n",
    "                return (torch.tensor(audio).unsqueeze(0),\n",
    "                        torch.tensor(label2id[genre], dtype=torch.long))\n",
    "            except Exception:\n",
    "                continue\n",
    "\n",
    "\n",
    "class ValDataset(Dataset):\n",
    "    def __init__(self, index):\n",
    "        self.samples = [(g, sp) for g in GENRES for sp in index[g]]\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.samples)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        genre, song_path = self.samples[idx]\n",
    "        audio = load_mix(song_path)\n",
    "        audio = crop_center(audio)\n",
    "        return (torch.tensor(audio).unsqueeze(0),\n",
    "                torch.tensor(label2id[genre], dtype=torch.long))\n",
    "\n",
    "\n",
    "train_ds = TrainDataset(train_index)\n",
    "val_ds   = ValDataset(val_index)\n",
    "\n",
    "train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True,\n",
    "                          num_workers=NUM_WORKERS, pin_memory=True,\n",
    "                          persistent_workers=True)\n",
    "val_loader   = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False,\n",
    "                          num_workers=NUM_WORKERS, pin_memory=True,\n",
    "                          persistent_workers=True)\n",
    "\n",
    "print(f'Train: {len(train_ds)} | Val: {len(val_ds)}')"
   ]
