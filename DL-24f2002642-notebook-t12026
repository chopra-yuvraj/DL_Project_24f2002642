orm(X_train)\nX_val_scaled = scaler.transform(X_val)\n\nmodel = MLPClassifier(\n    hidden_layer_sizes=(256, 128, 64),\n    activation='relu',\n    solver='adam',\n    max_iter=300,\n    random_state=42,\n    early_stopping=True\n)\n\nmodel.fit(X_train_scaled, y_train)\n\nval_predictions = model.predict(X_val_scaled)\naccuracy = accuracy_score(y_val, val_predictions)\n\nwandb.log({\"accuracy\": accuracy})\n\nval_predictions_decoded = label_encoder.inverse_transform(val_predictions)\ny_val_decoded = label_encoder.inverse_transform(y_val)\nwandb.sklearn.plot_confusion_matrix(y_val_decoded, val_predictions_decoded, label_encoder.classes_)\n\nrun.finish()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-19T09:18:20.369805Z","iopub.execute_input":"2026-02-19T09:18:20.376029Z","iopub.status.idle":"2026-02-19T09:18:34.579811Z","shell.execute_reply.started":"2026-02-19T09:18:20.375381Z","shell.execute_reply":"2026-02-19T09:18:34.577949Z"}},"outputs":[{"name":"stderr","text":"\u001b[34m\u001b[1mwandb\u001b[0m: W&B API key is configured. Use \u001b[1m`wandb login --relogin`\u001b[0m to force relogin\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":""},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":"Tracking run with wandb version 0.22.2"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":"Run data is saved locally in <code>/kaggle/working/wandb/run-20260219_091820-qjxqoele</code>"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":"Syncing run <strong><a href='https://wandb.ai/choprayuvraj-iit-madras/24f2002642-t12026/runs/qjxqoele' target=\"_blank\">MLPClassifier</a></strong> to <a href='https://wandb.ai/choprayuvraj-iit-madras/24f2002642-t12026' target=\"_blank\">Weights & Biases</a