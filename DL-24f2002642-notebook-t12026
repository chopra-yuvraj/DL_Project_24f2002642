ems'\ngenres = os.listdir(train_dir)\n\nprint(\"Converting audio to Spectrograms...\")\nfor genre in genres:\n    genre_path = os.path.join(train_dir, genre)\n    if os.path.isdir(genre_path):\n        song_folders = os.listdir(genre_path)\n        for song in tqdm(song_folders):\n            song_path = os.path.join(genre_path, song)\n            stems = os.listdir(song_path)\n            \n            mixed_y = None\n            sr_val = 22050\n            \n            for stem in stems:\n                if stem.endswith('.wav'):\n                    stem_path = os.path.join(song_path, stem)\n                    try:\n                        audio_y, sr = librosa.load(stem_path, duration=30)\n                        if mixed_y is None:\n                            mixed_y = audio_y\n                        else:\n                            min_len = min(len(mixed_y), len(audio_y))\n                            mixed_y = mixed_y[:min_len] + audio_y[:min_len]\n                    except Exception:\n                        continue\n            \n            if mixed_y is not None:\n                img = get_spectrogram(mixed_y, sr_val)\n                if img is not None:\n                    X_images.append(img)\n                    y_labels.append(genre)\n\nX = np.array(X_images)[..., np.newaxis] \ny_target = np.array(y_labels)\n\nprint(f\"Dataset Shape: {X.shape}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-21T05:24:21.743341Z","iopub.execute_input":"2026-02-21T05:24:21.743732Z","iopub.status.idle":"2026-02-21T05:33:21.931080Z","shell.execute_reply.started":"2026-02-21T05:24:21.743704Z","shell.execute_reply":"2026-02-21T05:33:21.930082Z"}},"outputs":[{"name":"stdout","text":"Converting audio to Spectrograms...\n","output_type":"stream"},{"name":"stderr","text":"100%|██████████| 100/100 [01:08<00:00,  1.47it/s]\n100%|██████████| 100/100 [00:50<00:00,  1.99it/s]\n100%|██████████| 100/100 [00:50<00:00,  2.00it/s]\n100%|██████████| 100/10