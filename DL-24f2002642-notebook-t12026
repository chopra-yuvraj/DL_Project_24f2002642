    "def load_and_mix_stems(genre_path, song_name):\n",
    "    \"\"\"Load all .wav stems in a folder, mix them, pad/trim to TARGET_LENGTH.\"\"\"\n",
    "    stem_files = [f for f in os.listdir(genre_path) if f.endswith('.wav')]\n",
    "    if not stem_files:\n",
    "        return None\n",
    "\n",
    "    mixed = None\n",
    "    for sf in stem_files:\n",
    "        try:\n",
    "            wf, sr = torchaudio.load(os.path.join(genre_path, sf))\n",
    "            if sr != TARGET_SR:\n",
    "                wf = T.Resample(sr, TARGET_SR)(wf)\n",
    "            if wf.shape[0] > 1:\n",
    "                wf = wf.mean(dim=0, keepdim=True)\n",
    "            # Pad / trim each stem to target length\n",
    "            if wf.shape[1] < TARGET_LENGTH:\n",
    "                wf = F.pad(wf, (0, TARGET_LENGTH - wf.shape[1]))\n",
    "            else:\n",
    "                wf = wf[:, :TARGET_LENGTH]\n",
    "            mixed = wf if mixed is None else mixed + wf\n",
    "        except Exception:\n",
    "            continue\n",
    "\n",
    "    if mixed is None:\n",
    "        return None\n",
    "\n",
    "    peak = torch.max(torch.abs(mixed))\n",
    "    if peak > 1e-6:\n",
    "        mixed = mixed / peak\n",
    "    return mixed  \n",
    "\n",
    "print('Scanning stems and loading into RAM — no files written to disk...')\n",
    "train_waveforms = []   \n",
    "\n",
    "genres = sorted([\n",
    "    g for g in os.listdir(STEMS_PATH)\n",
    "    if os.path.isdir(os.path.join(STEMS_PATH, g))\n",
    "])\n",
    "print(f'Genres ({len(genres)}): {genres}')\n",
    "\n",
    "for genre in genres:\n",
    "    genre_dir    = os.path.join(STEMS_PATH, genre)\n",
    "    song_folders = sorted(os.listdir(genre_dir))\n",
    "    for song in tqdm(song_folders, desc=f'  {genre}'):\n",
    "        song_dir = os.path.join(genre_dir, song)\n",
    "        if not os.path.isdir(song_dir):\n",
    "            continue\n",
    "        wf = load_and_mix_stems(song_dir, song)\n",
    "        if wf is not None:\n",
    "            train_waveforms.append((wf, genre))\n",
    "\n",
    "print(f'\\nTotal training samples cached in RAM: {len(train_waveforms)}')\n",
    "bytes_per_tensor = TARGET_LENGTH * 4  # float32\n",
    "total_mb = (len(train_waveforms) * bytes_per_tensor) / 1e6\n",
    "print(f'Approximate RAM used by waveforms: {total_mb:.1f} MB')\n"
   ]
