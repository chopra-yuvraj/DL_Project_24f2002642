    "    x = layers.Permute((2, 1, 3))(x) \n",
    "    x = layers.Reshape((40, 16 * 128))(x)\n",
    "    x = layers.Bidirectional(layers.LSTM(128, return_sequences=False))(x)\n",
    "    x = layers.Dropout(0.4)(x)\n",
