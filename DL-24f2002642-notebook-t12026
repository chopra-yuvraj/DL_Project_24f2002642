    "from tqdm import tqdm\n",
    "from transformers import get_cosine_schedule_with_warmup\n",
    "\n",
    "criterion = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
    "f1_metric = MulticlassF1Score(num_classes=NUM_LABELS, average='macro').to(DEVICE)\n",
    "\n",
    "\n",
    "def mixup(x, y, alpha=MIXUP_ALPHA):\n",
    "    lam   = np.random.beta(alpha, alpha)\n",
    "    idx   = torch.randperm(x.size(0), device=x.device)\n",
    "    x_mix = lam * x + (1 - lam) * x[idx]\n",
    "    return x_mix, y, y[idx], lam\n",
    "\n",
    "\n",
    "def run_epoch(model, loader, optimizer, scheduler, augment=False, train=True):\n",
    "    model.train() if train else model.eval()\n",
    "    f1_metric.reset()\n",
    "    total_loss = 0\n",
    "    total_acc  = 0\n",
    "    n = 0\n",
    "\n",
    "    ctx = torch.enable_grad() if train else torch.no_grad()\n",
    "    with ctx:\n",
    "        for wav, labels in tqdm(loader, desc='train' if train else 'val'):\n",
    "            wav    = wav.unsqueeze(1).to(DEVICE)\n",
    "            labels = labels.to(DEVICE)\n",
    "            img    = wav_to_3ch(wav, augment=augment)\n",
    "\n",
    "            use_mixup = train and (random.random() < MIXUP_PROB)\n",
    "            if use_mixup:\n",
    "                img, ya, yb, lam = mixup(img, labels)\n",
    "                logits = model(img)\n",
    "                loss   = lam * criterion(logits, ya) + (1 - lam) * criterion(logits, yb)\n",
    "            else:\n",
    "                logits = model(img)\n",
    "                loss   = criterion(logits, labels)\n",
    "\n",
    "            if train:\n",
    "                optimizer.zero_grad()\n",
    "                loss.backward()\n",
    "                torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "                optimizer.step()\n",
    "                scheduler.step()\n",
    "\n",
    "            preds = logits.argmax(dim=1)\n",
    "            total_loss += loss.item() * wav.size(0)\n",
    "            total_acc  += (preds == labels).sum().item()\n",
    "            f1_metric.update(preds, labels)\n",
    "            n += wav.size(0)\n",
    "\n",
    "    return total_loss / n, total_acc / n, f1_metric.compute().item()"
   ]
