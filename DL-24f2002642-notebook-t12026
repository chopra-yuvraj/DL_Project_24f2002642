    "    \n",
    "    model.compile(\n",
    "        optimizer=optimizer, \n",
    "        loss=tf.keras.losses.CategoricalCrossentropy(label_smoothing=0.1), \n",
    "        metrics=['accuracy']\n",
    "    )\n",
    "\n",
    "    lr_scheduler = ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=4, min_lr=1e-6, verbose=1)\n",
