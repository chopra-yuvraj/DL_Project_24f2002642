    "test_csv_path = '/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup/test.csv'\n",
    "test_dir = '/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup/mashups'\n",
    "test_df = pd.read_csv(test_csv_path)\n",
    "\n",
    "actual_files = os.listdir(test_dir)\n",
    "id_to_filename = {}\n",
    "for filename in actual_files:\n",
    "    if not filename.endswith('.wav'): continue\n",
    "    digits = ''.join(filter(str.isdigit, filename))\n",
    "    if digits:\n",
    "        id_to_filename[int(digits)] = filename\n",
    "\n",
    "submission_data = []\n",
    "\n",
    "for index, row in tqdm(test_df.iterrows(), total=len(test_df)):\n",
    "    song_id = row['id']\n",
    "    filename = id_to_filename.get(song_id)\n",
    "    \n",
    "    if filename:\n",
    "        file_path = os.path.join(test_dir, filename)\n",
    "        try:\n",
    "            audio_y, sr = librosa.load(file_path, duration=30)\n",
    "            img = get_spectrogram(audio_y, sr)\n",
    "            \n",
    "            if img is not None:\n",
    "                img_input = img[np.newaxis, ..., np.newaxis] \n",
    "                pred_probs = model.predict(img_input, verbose=0)\n",
    "                pred_num = np.argmax(pred_probs)\n",
    "                pred_label = label_encoder.inverse_transform([pred_num])[0]\n",
    "                submission_data.append([song_id, pred_label])\n",
    "            else:\n",
    "                submission_data.append([song_id, \"pop\"])\n",
    "        except Exception:\n",
    "            submission_data.append([song_id, \"pop\"])\n",
    "    else:\n",
    "        submission_data.append([song_id, \"pop\"])\n",
    "\n",
    "submission_df = pd.DataFrame(submission_data, columns=['id', 'genre'])\n",
    "submission_df.to_csv('submission_cnn_noise.csv', index=False)\n",
    "print(submission_df.head())"
   ]
