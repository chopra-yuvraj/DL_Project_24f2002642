    "def get_mel_spec(y, sr=SR, n_mels=N_MELS, max_len=MAX_LEN):\n",
    "    mel  = librosa.feature.melspectrogram(y=y, sr=sr, n_mels=n_mels, fmax=8000)\n",
    "    spec = librosa.power_to_db(mel, ref=np.max)\n",
    "    if spec.shape[1] < max_len:\n",
    "        spec = np.pad(spec, ((0, 0), (0, max_len - spec.shape[1])))\n",
    "    else:\n",
    "        spec = spec[:, :max_len]\n",
    "    return spec.astype(np.float32)\n",
    "\n",
    "\n",
    "noise_files = [os.path.join(NOISE_PATH, f) for f in os.listdir(NOISE_PATH) if f.endswith('.wav')]\n",
    "genres      = sorted([g for g in os.listdir(STEMS_PATH) if os.path.isdir(os.path.join(STEMS_PATH, g))])\n",
    "\n",
    "X_specs  = []\n",
    "y_labels = []\n",
    "\n",
    "for genre in genres:\n",
    "    genre_path = os.path.join(STEMS_PATH, genre)\n",
    "    for song in tqdm(sorted(os.listdir(genre_path)), desc=genre):\n",
    "        song_path = os.path.join(genre_path, song)\n",
    "        if not os.path.isdir(song_path):\n",
    "            continue\n",
    "\n",
    "        mixed_y = None\n",
    "        for stem_file in os.listdir(song_path):\n",
    "            if not stem_file.endswith('.wav'):\n",
    "                continue\n",
    "            try:\n",
    "                y, _ = librosa.load(os.path.join(song_path, stem_file), sr=SR, duration=30)\n",
    "                if mixed_y is None:\n",
    "                    mixed_y = y\n",
    "                else:\n",
    "                    min_len = min(len(mixed_y), len(y))\n",
    "                    mixed_y = mixed_y[:min_len] + y[:min_len]\n",
    "            except Exception:\n",
    "                continue\n",
    "\n",
    "        if mixed_y is not None and noise_files:\n",
    "            try:\n",
    "                noise_y, _ = librosa.load(random.choice(noise_files), sr=SR, duration=30)\n",
    "                min_len     = min(len(mixed_y), len(noise_y))\n",
    "                mixed_y[:min_len] += noise_y[:min_len] * 0.2\n",
    "            except Exception:\n",
    "                pass\n",
    "\n",
    "        if mixed_y is not None:\n",
    "            X_specs.append(get_mel_spec(mixed_y))\n",
    "            y_labels.append(genre)\n",
    "\n",
    "X = np.array(X_specs, dtype=np.float32)\n",
    "print(f'Dataset shape: {X.shape}')"
   ]
