    "def mixup_batch(x, y, alpha=MIXUP_ALPHA):\n",
    "    lam = np.random.beta(alpha, alpha)\n",
    "    idx = torch.randperm(x.size(0), device=x.device)\n",
    "    return lam * x + (1 - lam) * x[idx], y, y[idx], lam\n",
    "\n",
    "\n",
    "criterion  = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
    "optimizer  = torch.optim.AdamW(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)\n",
    "f1_metric  = MulticlassF1Score(num_classes=len(GENRES), average='macro').to(DEVICE)\n",
    "scheduler  = torch.optim.lr_scheduler.CosineAnnealingLR(\n",
    "    optimizer, T_max=len(train_loader) * EPOCHS\n",
    ")\n",
    "\n",
    "run = wandb.init(\n",
    "    entity  = 'choprayuvraj-iit-madras',\n",
    "    project = '24f2002642-t12026',\n",
    "    name    = 'MelCNN-Scratch',\n",
    "    config  = {\n",
    "        'architecture': 'MelCNN', 'epochs': EPOCHS,\n",
    "        'lr': LR, 'batch_size': BATCH_SIZE,\n",
    "        'n_mels': N_MELS, 'duration': DURATION,\n",
    "        'mixup_alpha': MIXUP_ALPHA, 'train_size': TRAIN_SIZE\n",
    "    }\n",
    ")\n",
    "\n",
    "best_val_f1 = 0\n",
    "best_path   = '/kaggle/working/best_cnn.pth'\n",
    "\n",
    "for epoch in range(EPOCHS):\n",
    "    model.train()\n",
    "    f1_metric.reset()\n",
    "    run_loss = 0.0\n",
    "    correct  = 0\n",
    "    n_total  = 0\n",
    "\n",
    "    for wav, labels in tqdm(train_loader, desc=f'Train {epoch+1}/{EPOCHS}'):\n",
    "        wav    = wav.to(DEVICE)\n",
    "        labels = labels.to(DEVICE)\n",
    "        spec   = to_mel(wav, augment=True)\n",
    "\n",
    "        use_mixup = random.random() < MIXUP_PROB\n",
    "        if use_mixup:\n",
    "            spec, labels_a, labels_b, lam = mixup_batch(spec, labels)\n",
    "            logits      = model(spec)\n",
    "            loss        = lam * criterion(logits, labels_a) + (1 - lam) * criterion(logits, labels_b)\n",
    "            true_labels = labels_a\n",
    "        else:\n",
    "            logits      = model(spec)\n",
    "            loss        = criterion(logits, labels)\n",
    "            true_labels = labels\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "        optimizer.step()\n",
    "        scheduler.step()\n",
    "\n",
    "        run_loss += loss.item()\n",
    "        preds     = logits.argmax(dim=1)\n",
    "        correct  += (preds == true_labels).sum().item()\n",
    "        n_total  += labels.size(0)\n",
    "        f1_metric.update(preds, true_labels)\n",
    "\n",
    "    train_loss = run_loss / len(train_loader)\n",
    "    train_acc  = correct / n_total\n",
    "    train_f1   = f1_metric.compute().item()\n",
    "\n",
    "    model.eval()\n",
    "    f1_metric.reset()\n",
    "    v_loss = 0.0\n",
    "    v_corr = 0\n",
    "    v_tot  = 0\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for wav, labels in tqdm(val_loader, desc='Val'):\n",
    "            wav    = wav.to(DEVICE)\n",
    "            labels = labels.to(DEVICE)\n",
    "            spec   = to_mel(wav, augment=False)\n",
    "            logits = model(spec)\n",
    "            v_loss += criterion(logits, labels).item()\n",
    "            preds   = logits.argmax(dim=1)\n",
    "            v_corr += (preds == labels).sum().item()\n",
    "            v_tot  += labels.size(0)\n",
    "            f1_metric.update(preds, labels)\n",
    "\n",
    "    val_loss = v_loss / len(val_loader)\n",
    "    val_acc  = v_corr / v_tot\n",
    "    val_f1   = f1_metric.compute().item()\n",
    "    cur_lr   = scheduler.get_last_lr()[0]\n",
    "\n",
    "    wandb.log({\n",
    "        'epoch': epoch + 1,\n",
    "        'train_loss': train_loss, 'train_acc': train_acc,\n",
    "        'val_loss':   val_loss,   'val_acc':   val_acc,\n",
    "        'val_f1':     val_f1,     'lr':        cur_lr\n",
    "    })\n",
    "\n",
    "    print(f'Ep {epoch+1}/{EPOCHS} | '\n",
    "          f'train_loss={train_loss:.4f} train_acc={train_acc:.4f} '\n",
    "          f'val_loss={val_loss:.4f} val_acc={val_acc:.4f} val_f1={val_f1:.4f}')\n",
    "\n",
    "    if val_f1 > best_val_f1:\n",
    "        best_val_f1 = val_f1\n",
    "        torch.save(model.state_dict(), best_path)\n",
    "\n",
    "wandb.finish()\n",
    "print(f'Best val F1: {best_val_f1:.4f}')"
