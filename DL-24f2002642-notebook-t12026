    "for f in os.listdir(MASHUPS_PATH):\n",
    "    if f.endswith('.wav'):\n",
    "        digits = ''.join(filter(str.isdigit, f))\n",
    "        if digits:\n",
    "            id_to_file[int(digits)] = f\n",
    "\n",
    "all_ids   = []\n",
    "all_preds = []\n",
    "\n",
    "for idx in tqdm(range(len(test_df)), desc='Inference'):\n",
    "    sid   = test_df.iloc[idx]['id']\n",
    "    fname = id_to_file.get(sid)\n",
    "    label = 'pop'   # fallback\n",
    "\n",
    "    if fname:\n",
    "        try:\n",
    "            audio, _ = librosa.load(\n",
    "                os.path.join(MASHUPS_PATH, fname),\n",
    "                sr=SAMPLE_RATE, mono=True\n",
    "            )\n",
    "            audio = audio / (np.max(np.abs(audio)) + 1e-6)\n",
    "\n",
    "            avg_probs = np.zeros(len(GENRES))\n",
    "            for _ in range(N_TTA):\n",
    "                clip  = random_crop(audio)\n",
    "                feats = extract_features(clip).reshape(1, -1)\n",
    "                # average predictions across all 5 CV folds\n",
    "                fold_probs = np.mean([m.predict(feats)[0] for m in models], axis=0)\n",
    "                avg_probs += fold_probs\n",
    "\n",
    "            label = id2label[int(np.argmax(avg_probs))]\n",
    "        except Exception as e:\n",
    "            print(f'  skip {sid}: {e}')\n",
    "\n",
    "    all_ids.append(sid)\n",
    "    all_preds.append(label)\n",
