    "run = wandb.init(\n",
    "    entity   = 'choprayuvraj-iit-madras',\n",
    "    project  = '24f2002642-t12026',\n",
    "    name     = 'RAM-Cache EfficientNet-B1 PyTorch v4',\n",
    "    job_type = 'train',\n",
    "    config   = {\n",
    "        'epochs': EPOCHS, 'lr': LR, 'batch_size': BATCH_SIZE,\n",
    "        'n_mels': N_MELS, 'architecture': 'EfficientNet-B1',\n",
    "        'label_smoothing': 0.1, 'weight_decay': 1e-2\n",
    "    }\n",
    ")\n",
    "\n",
    "best_val_f1 = 0.0\n",
    "\n",
    "for epoch in range(EPOCHS):\n",
    "    model.train()\n",
    "    tr_loss, tr_preds, tr_true = 0.0, [], []\n",
    "\n",
    "    for specs, labels in tqdm(train_loader, desc=f'Ep {epoch+1}/{EPOCHS}', leave=False):\n",
    "        specs, labels = specs.to(device), labels.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        out  = model(specs)\n",
    "        loss = criterion(out, labels)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        tr_loss += loss.item() * specs.size(0)\n",
    "        tr_preds.extend(out.argmax(1).cpu().numpy())\n",
    "        tr_true.extend(labels.cpu().numpy())\n",
    "\n",
    "    model.eval()\n",
    "    val_loss, val_preds, val_true = 0.0, [], []\n",
    "    with torch.no_grad():\n",
    "        for specs, labels in val_loader:\n",
    "            specs, labels = specs.to(device), labels.to(device)\n",
    "            out  = model(specs)\n",
    "            loss = criterion(out, labels)\n",
    "            val_loss += loss.item() * specs.size(0)\n",
    "            val_preds.extend(out.argmax(1).cpu().numpy())\n",
    "            val_true.extend(labels.cpu().numpy())\n",
    "\n",
    "    scheduler.step()\n",
    "\n",
    "    t_f1  = f1_score(tr_true,  tr_preds,  average='macro', zero_division=0)\n",
    "    v_f1  = f1_score(val_true, val_preds, average='macro', zero_division=0)\n",
    "    t_acc = (np.array(tr_preds) == np.array(tr_true)).mean()\n",
    "    v_acc = (np.array(val_preds) == np.array(val_true)).mean()\n",
    "\n",
    "    wandb.log({\n",
    "        'epoch': epoch + 1,\n",
    "        'train_loss': tr_loss / len(train_ds), 'val_loss': val_loss / len(val_ds),\n",
    "        'train_acc': t_acc, 'val_acc': v_acc,\n",
    "        'train_f1': t_f1,   'val_f1': v_f1,\n",
    "        'lr': optimizer.param_groups[0]['lr']\n",
    "    })\n",
    "\n",
    "    print(f'Ep {epoch+1:02d} | trn loss={tr_loss/len(train_ds):.4f} acc={t_acc:.3f} f1={t_f1:.3f} | val loss={val_loss/len(val_ds):.4f} acc={v_acc:.3f} f1={v_f1:.3f}')\n",
    "\n",
    "    if v_f1 > best_val_f1:\n",
    "        best_val_f1 = v_f1\n",
    "        torch.save(model.state_dict(), '/kaggle/working/best_model.pth')\n",
    "\n",
    "wandb.finish()\n",
    "print(f'Best Val F1: {best_val_f1:.4f}')"
   ]
