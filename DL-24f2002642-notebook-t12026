    "INPUT_BASE = '/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup'\n",
    "WORKING_BASE = '/kaggle/working'\n",
    "STEMS_PATH = os.path.join(INPUT_BASE, 'genres_stems')\n",
    "NOISE_PATH = os.path.join(INPUT_BASE, 'ESC-50-master/audio')\n",
    "PREMIXED_TRAIN_DIR = os.path.join(WORKING_BASE, 'premixed_train')\n",
    "\n",
    "os.makedirs(PREMIXED_TRAIN_DIR, exist_ok=True)\n",
    "\n",
    "train_data = []\n",
    "genres = os.listdir(STEMS_PATH)\n",
    "target_sr = 22050\n",
    "target_length = target_sr * 30\n",
    "\n",
    "for genre in genres:\n",
    "    genre_path = os.path.join(STEMS_PATH, genre)\n",
    "    if os.path.isdir(genre_path):\n",
    "        song_folders = os.listdir(genre_path)\n",
    "        for song in tqdm(song_folders):\n",
    "            song_path = os.path.join(genre_path, song)\n",
    "            stems = [os.path.join(song_path, s) for s in os.listdir(song_path) if s.endswith('.wav')]\n",
    "            \n",
    "            if stems:\n",
    "                mixed_waveform = None\n",
    "                for path in stems:\n",
    "                    waveform, sr = torchaudio.load(path)\n",
    "                    if sr != target_sr:\n",
    "                        waveform = T.Resample(sr, target_sr)(waveform)\n",
    "                    if waveform.shape[0] > 1:\n",
    "                        waveform = torch.mean(waveform, dim=0, keepdim=True)\n",
    "                        \n",
    "                    if mixed_waveform is None:\n",
    "                        mixed_waveform = waveform\n",
    "                    else:\n",
    "                        min_len = min(mixed_waveform.shape[1], waveform.shape[1])\n",
    "                        mixed_waveform = mixed_waveform[:, :min_len] + waveform[:, :min_len]\n",
    "                \n",
    "                if mixed_waveform.shape[1] < target_length:\n",
    "                    mixed_waveform = torch.nn.functional.pad(mixed_waveform, (0, target_length - mixed_waveform.shape[1]))\n",
    "                else:\n",
    "                    mixed_waveform = mixed_waveform[:, :target_length]\n",
    "                    \n",
    "                mixed_waveform = mixed_waveform / (torch.max(torch.abs(mixed_waveform)) + 1e-6)\n",
    "                \n",
    "                save_name = f\"{genre}_{song}.wav\"\n",
    "                save_path = os.path.join(PREMIXED_TRAIN_DIR, save_name)\n",
    "                torchaudio.save(save_path, mixed_waveform, target_sr)\n",
    "                train_data.append({'file_path': save_path, 'genre': genre})\n",
    "\n",
    "df = pd.DataFrame(train_data)\n",
    "label_encoder = LabelEncoder()\n",
    "df['label'] = label_encoder.fit_transform(df['genre'])\n",
    "\n",
    "train_df, val_df = train_test_split(df, test_size=0.2, stratify=df['label'], random_state=42)\n",
    "train_df = train_df.reset_index(drop=True)\n",
    "val_df = val_df.reset_index(drop=True)\n",
    "\n",
    "noise_files = glob.glob(os.path.join(NOISE_PATH, '**', '*.wav'), recursive=True)\n",
    "loaded_noises = []\n",
    "for nf in noise_files:\n",
    "    n_wave, n_sr = torchaudio.load(nf)\n",
    "    if n_sr != target_sr:\n",
    "        n_wave = T.Resample(n_sr, target_sr)(n_wave)\n",
    "    if n_wave.shape[0] > 1:\n",
    "        n_wave = torch.mean(n_wave, dim=0, keepdim=True)\n",
    "    loaded_noises.append(n_wave)"
   ]
