    "def get_spectrogram(y_audio, sr, max_len=431):\n",
    "    try:\n",
    "        mel_spec = librosa.feature.melspectrogram(y=y_audio, sr=sr, n_mels=128, fmax=8000)\n",
    "        \n",
    "        pcen_spec = librosa.pcen(S=mel_spec, sr=sr)\n",
    "        pcen_spec = (pcen_spec - np.min(pcen_spec)) / (np.max(pcen_spec) - np.min(pcen_spec) + 1e-6)\n",
    "        \n",
    "        if pcen_spec.shape[1] < max_len:\n",
    "            pad_width = max_len - pcen_spec.shape[1]\n",
    "            pcen_spec = np.pad(pcen_spec, pad_width=((0, 0), (0, pad_width)), mode='constant')\n",
    "        else:\n",
    "            pcen_spec = pcen_spec[:, :max_len]\n",
    "            \n",
    "        return pcen_spec\n",
    "    except Exception:\n",
    "        return None"
   ]
