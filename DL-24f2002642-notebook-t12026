    "# Load Pre-trained EfficientNet-B0\n",
    "model = models.efficientnet_b0(pretrained=True)\n",
    "\n",
    "# Replace the final classification head for our 10 audio genres\n",
    "num_ftrs = model.classifier[1].in_features\n",
    "model.classifier = nn.Sequential(\n",
    "    nn.Dropout(p=0.4, inplace=True),\n",
    "    nn.Linear(num_ftrs, 10)\n",
    ")\n",
    "\n",
    "model = model.to(device)\n",
    "criterion = nn.CrossEntropyLoss(label_smoothing=0.1) # Added label smoothing for robustness against noisy data\n",
    "\n",
    "# Fine-tuning optimizer (smaller learning rate since it is pre-trained)\n",
    "optimizer = optim.Adam(model.parameters(), lr=0.0001)\n",
    "scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=3)"
   ]
