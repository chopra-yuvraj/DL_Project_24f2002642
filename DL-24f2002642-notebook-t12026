    "from tqdm import tqdm\n",
    "\n",
    "def predict_tta(model, audio, n_tta=N_TTA):\n",
    "    all_probs = []\n",
    "    for _ in range(n_tta):\n",
    "        seg = crop_random(audio)\n",
    "        seg = normalize(seg)\n",
    "        wav = torch.tensor(seg).unsqueeze(0).unsqueeze(0).to(DEVICE)\n",
    "        with torch.no_grad():\n",
    "            img    = wav_to_3ch(wav, augment=False)\n",
    "            logits = model(img)\n",
    "            probs  = torch.softmax(logits, dim=1)\n",
    "            all_probs.append(probs.cpu().numpy())\n",
    "    avg = np.mean(all_probs, axis=0)\n",
    "    return int(np.argmax(avg, axis=1)[0])\n",
    "\n",
    "\n",
    "model.load_state_dict(torch.load('/kaggle/working/best_model_phase2.pth'))\n",
    "model.eval()\n",
    "\n",
    "test_df    = pd.read_csv(os.path.join(BASE_PATH, 'test.csv'))\n",
    "\n",
    "id_to_file = {}\n",
    "for f in os.listdir(MASHUPS_PATH):\n",
    "    if f.endswith('.wav'):\n",
    "        digits = ''.join(filter(str.isdigit, f))\n",
    "        if digits:\n",
    "            id_to_file[int(digits)] = f\n",
    "\n",
    "all_ids   = []\n",
    "all_preds = []\n",
    "\n",
    "for idx in tqdm(range(len(test_df)), desc=f'Inference (TTA x{N_TTA})'):\n",
    "    row   = test_df.iloc[idx]\n",
    "    sid   = row['id']\n",
    "    fname = id_to_file.get(sid)\n",
    "    label = 'pop'\n",
    "    if fname:\n",
    "        try:\n",
    "            audio = load_audio(os.path.join(MASHUPS_PATH, fname))\n",
    "            pred  = predict_tta(model, audio)\n",
    "            label = id2label[pred]\n",
    "        except Exception:\n",
    "            pass\n",
    "    all_ids.append(sid)\n",
    "    all_preds.append(label)\n",
    "\n",
    "submission = pd.DataFrame({'id': all_ids, 'genre': all_preds})\n",
    "submission.to_csv('/kaggle/working/submission.csv', index=False)\n",
    "print(submission['genre'].value_counts())"
