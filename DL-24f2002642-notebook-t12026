    "label_encoder = LabelEncoder()\n",
    "y_enc         = label_encoder.fit_transform(np.array(y_all))\n",
    "y_genres      = np.array(y_all)\n",
    "print('Classes:', list(label_encoder.classes_))\n",
    "\n",
    "X_tr, X_val, y_tr, y_val, yg_tr, yg_val = train_test_split(\n",
    "    X, y_enc, y_genres, test_size=0.2, stratify=y_enc, random_state=42\n",
    ")\n",
    "\n",
    "X_mean = float(X_tr.mean())\n",
    "X_std  = float(X_tr.std()) + 1e-6\n",
    "X_tr   = (X_tr  - X_mean) / X_std\n",
    "X_val  = (X_val - X_mean) / X_std\n",
    "\n",
    "genre_spec_dict_norm = {\n",
    "    g: [(s - X_mean) / X_std for s in specs]\n",
    "    for g, specs in genre_spec_dict.items()\n",
    "}\n",
    "\n",
    "\n",
    "class MixDataset(Dataset):\n",
    "    def __init__(self, specs, labels, genre_names, is_train=True):\n",
    "        self.specs       = specs\n",
    "        self.labels      = labels\n",
    "        self.genre_names = genre_names\n",
    "        self.is_train    = is_train\n",
    "        self.freq_m      = T.FrequencyMasking(freq_mask_param=20)\n",
    "        self.time_m      = T.TimeMasking(time_mask_param=80)\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.specs)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        spec  = self.specs[idx].copy()\n",
    "        label = self.labels[idx]\n",
    "\n",
    "        if self.is_train and random.random() < 0.5:\n",
    "            genre = self.genre_names[idx]\n",
    "            other = random.choice(genre_spec_dict_norm[genre])\n",
    "            alpha = random.uniform(0.3, 0.7)\n",
    "            spec  = alpha * spec + (1.0 - alpha) * other\n",
    "\n",
    "        spec = torch.tensor(spec).unsqueeze(0)\n",
    "        if self.is_train:\n",
    "            spec = self.freq_m(spec)\n",
    "            spec = self.time_m(spec)\n",
    "\n",
    "        return spec.repeat(3, 1, 1), torch.tensor(label, dtype=torch.long)\n",
    "\n",
    "\n",
    "train_ds = MixDataset(X_tr,  y_tr,  yg_tr,  is_train=True)\n",
    "val_ds   = MixDataset(X_val, y_val, yg_val, is_train=False)\n",
    "\n",
    "train_loader = DataLoader(train_ds, batch_size=BATCH, shuffle=True,  num_workers=2, pin_memory=True)\n",
    "val_loader   = DataLoader(val_ds,   batch_size=BATCH, shuffle=False, num_workers=2, pin_memory=True)"
   ]
