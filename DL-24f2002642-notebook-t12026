quential([\n    layers.Input(shape=(128, 1292, 1)),\n    layers.Conv2D(32, (3, 3), activation='relu'),\n    layers.BatchNormalization(),\n    layers.MaxPooling2D((2, 4)),\n    \n    layers.Conv2D(64, (3, 3), activation='relu'),\n    layers.BatchNormalization(),\n    layers.MaxPooling2D((2, 4)),\n    \n    layers.Flatten(),\n    layers.Dense(64, activation='relu'),\n    layers.Dropout(0.5),\n    layers.Dense(10, activation='softmax')\n])\n\nmodel.compile(optimizer='adam',\n              loss='sparse_categorical_crossentropy',\n              metrics=['accuracy'])\n\nclass SimpleWandbCallback(tf.keras.callbacks.Callback):\n    def on_epoch_end(self, epoch, logs=None):\n        wandb.log(logs)\n\nprint(\"Training the Anti-Overfit CNN on Noisy Data...\")\nhistory = model.fit(\n    X_train, y_train, \n    epochs=15, \n    batch_size=16,\n    validation_data=(X_val, y_val),\n    callbacks=[SimpleWandbCallback()]\n)\n\nrun.finish()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-21T06:11:01.055759Z","iopub.execute_input":"2026-02-21T06:11:01.060799Z","iopub.status.idle":"2026-02-21T06:23:55.209331Z","shell.execute_reply.started":"2026-02-21T06:11:01.060740Z","shell.execute_reply":"2026-02-21T06:23:55.208156Z"}},"outputs":[{"name":"stderr","text":"\u001b[34m\u001b[1mwandb\u001b[0m: W&B API key is configured. Use \u001b[1m`wandb login --relogin`\u001b[0m to force relogin\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":""},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":"Tracking run with wandb version 0.22.2"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":"Run data is saved locally in <code>/kaggle/working/wandb/run-20260221_061101-i41usl83</code>"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML o